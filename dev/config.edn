{:paths
 {:src "src"
  :test "test"
  :dev "dev"
  :agent "agent"
  :docs "docs"
  :scripts "dev/scripts"
  :logs "logs"
  :test-results "test-results"}
 
 :ports
 {:nrepl 7888
  :dev-server 8080
  :shadow-cljs 9630}
 
 :timeouts
 {:test-ms 30000
  :repl-eval-ms 10000
  :compilation-ms 120000
  :server-start-ms 15000}
 
 :linting
 {:fail-level :error
  :exclude-ns ["legacy.*" "deprecated.*"]
  :parallel? true}
 
 :caching
 {:max-cache-mb 500
  :auto-clean-threshold-mb 1000
  :dirs [".shadow-cljs" "out" "target" "node_modules/.cache"]}
 
 :testing
 {:parallel? false
  :watch? false
  :log-results? true
  :save-results? true}
 
 :builds
 {:frontend {:target :browser :output-dir "public/js"}
  :test {:target :node-test :output-to "out/tests.js"}}
 
 :dev-tools
 {:clj-kondo {:version "latest" :config ".clj-kondo/config.edn"}
  :shadow-cljs {:version "3.2.0"}
  :nrepl {:version "1.3.1"}}}