{:version "1.0.0"
 :description "Toolbox index for all development tooling - MCPs, Skills, CLIs, Scripts"

 ;; === MCPs (Model Context Protocol servers) ===
 ;; Long-running, stateful services
 :mcps
 {:tournament
  {:type :mcp
   :status :available
   :deployment :dual  ; Both MCP server AND global CLI via uv
   :path "~/Projects/tournament-mcp/"
   :description "Bradley-Terry ranking via Swiss-Lite tournaments"
   :cli-command "tournament"  ; Available as CLI: uv tool install ~/Projects/tournament-mcp
   :mcp-config ".mcp.json"    ; Also runs as MCP server
   :triggers ["compare items" "rank proposals" "run tournament"]
   :note "Dual deployment: MCP for Claude, CLI for skills/scripts"}

  :shadow-cljs
  {:type :mcp
   :status :available
   :description "Clojure/ClojureScript REPL integration"
   :config ".mcp.json"
   :stateful true
   :long-running true}

  :exa
  {:type :mcp
   :status :available
   :description "Third-party code/web search service"
   :config ".mcp.json"
   :network-required true}

  :context7
  {:type :mcp
   :status :available
   :description "Library documentation lookup"
   :network-required true}}

 ;; === Skills (Progressive-disclosure resources) ===
 ;; Filesystem-based, L1/L2/L3 loading
 :skills
 {:architect
  {:type :skill
   :status :available
   :path "skills/architect/"
   :description "Architectural proposals → tournament → ADR workflow"
   :triggers ["propose" "architecture" "adr" "design decision" "review" "tournament"]
   :resources ["tournament-mcp integration" "LLM CLI orchestration" "ADR templates"]
   :network-required true  ; Calls LLM CLIs
   :state-dir ".architect/"
   :docs-ref "CLAUDE.md#agent-skills-overview"
   :note "Migrated from MCP to Skill (2025-10-17)"}

  :research
  {:type :skill
   :status :available
   :path "skills/research/"
   :description "Query ~/Projects/best/* repos using repomix + LLM CLIs"
   :triggers ["research best-of repo" "query reference projects" "explore codebase patterns"]
   :resources ["repos.edn" "repomix wrapper" "LLM CLI orchestration"]
   :network-required true  ; Calls LLM CLIs
   :docs-ref "CLAUDE.md#research-workflow"}

  :visual-validate
  {:type :skill
   :status :available
   :path "skills/visual/"
   :description "Canvas/WebGL analysis - geometry, lighting, wave patterns"
   :triggers ["validate visual output" "analyze canvas" "compare reference"]
   :resources ["Python analysis scripts" "ML models" "reference data"]
   :docs-ref "CLAUDE.md#visual-validation"}

  :repl-debug
  {:type :skill
   :status :available
   :path "skills/repl-debug/"
   :description "REPL-first debugging patterns and browser console helpers"
   :triggers ["debug issue" "repl workflow" "browser console"]
   :resources ["DEBUG helpers" "common patterns" "pitfall catalog"]
   :docs-ref "CLAUDE.md#debugging-workflow"}

  :dev-diagnostics
  {:type :skill
   :status :available
   :path "skills/diagnostics/"
   :description "Environment validation, health checks, error catalog"
   :triggers ["health check" "validate environment" "diagnose error"]
   :resources ["health.clj" "error-catalog.edn" "preflight checks"]
   :docs-ref "CLAUDE.md#dev-tooling"}}

 ;; === CLIs (Command-line tools) ===
 ;; Simple wrappers, composable in pipes
 :clis
 {:gemini
  {:type :cli
   :path "gemini"  ; In PATH
   :description "Google Gemini API wrapper"
   :network-required true
   :session-support true
   :env-vars ["GEMINI_API_KEY"]
   :use-cases ["HUMAN INTERACTIVE USE ONLY" "high token-count queries" "multi-turn research" "MCP-aware queries"]
   :note "NOT for agent scripts (use llmx)"
   :docs-ref "CLAUDE.md#unified-toolchain"}

  :codex
  {:type :cli
   :path "codex"  ; In PATH
   :description "OpenAI Codex wrapper"
   :network-required true
   :session-support true
   :env-vars ["OPENAI_API_KEY"]
   :use-cases ["HUMAN INTERACTIVE USE ONLY" "code review" "taste/style questions" "architecture" "reasoning_effort=high"]
   :note "NOT for agent scripts (use llmx)"
   :docs-ref "CLAUDE.md#unified-toolchain"}

  :llmx
  {:type :cli
   :path "llmx"  ; In PATH via uv tool install
   :description "Unified API wrapper for 100+ LLM providers via LiteLLM"
   :status :PRIMARY-CLI-FOR-AGENT-SCRIPTS
   :deployment :global-uv
   :network-required true
   :providers ["google" "openai" "anthropic" "xai" "deepseek" "100+ via LiteLLM"]
   :features ["reasoning-effort support for OpenAI o1/GPT-5" "provider comparison" "streaming"]
   :env-vars ["GEMINI_API_KEY" "OPENAI_API_KEY" "ANTHROPIC_API_KEY" "XAI_API_KEY" "DEEPSEEK_API_KEY"]
   :use-cases ["ALL agent scripts" "skills orchestration" "provider comparison" "reasoning-effort queries"]
   :replaces ["Vendor CLI calls in code-research skill" "Custom providers.py in architect skill" "scripts/grok" "scripts/.archived-gemini-api" "scripts/.archived-openai"]
   :install "uv tool install ~/Projects/llmx"
   :also-importable true  ; Can be imported in Python like tournament
   :migration-date "2025-10-17"
   :docs-ref "CLAUDE.md#unified-toolchain"}

  :opencode
  {:type :cli
   :path "opencode"  ; In PATH
   :description "DeepSeek OpenCode wrapper"
   :network-required true
   :env-vars ["OPENCODE_API_KEY"]}

  :repomix
  {:type :cli
   :path "repomix"  ; In PATH
   :description "Bundle repository for LLM context"
   :use-cases ["prepare codebase for LLM query" "extract code patterns"]
   :docs-ref "CLAUDE.md#research-workflow"}

  :tournament
  {:type :cli
   :path "tournament"  ; In PATH via uv tool install
   :description "Tournament evaluation CLI (also available as MCP)"
   :deployment :global-uv
   :use-cases ["rank proposals in architect skill" "batch comparisons"]
   :also-available-as :mcp
   :install "uv tool install ~/Projects/tournament-mcp"
   :docs-ref "CLAUDE.md#mcps"}}

 ;; === Scripts (Simple automation) ===
 ;; Keep as bash scripts, don't over-engineer
 :scripts
 {:generate-overview
  {:type :script
   :path "scripts/generate-overview.sh"
   :description "Generate AI architectural overviews"
   :args ["--source" "--project" "--auto" "-t path" "-m model"]
   :outputs ["dev/overviews/AUTO-SOURCE-OVERVIEW.md" "dev/overviews/AUTO-PROJECT-OVERVIEW.md"]}

  :quick-test
  {:type :script
   :path "scripts/quick-test.sh"
   :description "Run specific test namespace quickly"
   :args ["[namespace]"]
   :examples ["scripts/quick-test.sh lab.anki.core-test"]}

  :install-hooks
  {:type :script
   :path "scripts/install-hooks.sh"
   :description "Install git pre-commit hooks"}

  :visual-analyze-reference
  {:type :script
   :path "scripts/visual-analyze-reference"
   :description "Extract wave patterns, lighting, geometry from reference image"
   :deps ["Python" "OpenCV"]}

  :visual-compare-actionable
  {:type :script
   :path "scripts/visual-compare-actionable"
   :description "Compare reference vs implementation, get specific fixes"
   :deps ["Python" "OpenCV"]}}

 ;; === Task Runners ===
 :task-runners
 {:babashka
  {:type :task-runner
   :config "bb.edn"
   :status :PRIMARY
   :tasks [:lint :check :test :fix-cache
           :health :preflight :env-debug :research
           :dev :repl-health :docs-overview :install-hooks]
   :note "Unified Clojure-native task runner (created 2025-10-17)"
   :docs-ref "CLAUDE.md#unified-toolchain"}

  :npm
  {:type :task-runner
   :config "package.json"
   :status :LEGACY
   :scripts [:lint :check :test "fix:cache" "agent:health" "agent:preflight"]
   :note "Still available, but bb tasks preferred"}}

 ;; === REPL ===
 :repl
 {:namespace 'repl
  :path "dev/repl/init.clj"
  :status :CONSOLIDATED
  :entry-point 'go!
  :functions
  {:go! "One-command startup: connect, load namespaces, health check"
   :connect! "Connect to shadow-cljs REPL"
   :init! "Load core namespaces"
   :quick-health-check! "REPL diagnostics"
   :rt! "Run all tests"
   :rq! "Reload and run specific test"
   :save-session! "Save REPL session state"
   :restore-session! "Restore REPL session"
   :cljs! "Evaluate ClojureScript in browser"
   :clj! "Evaluate Clojure on JVM"}
  :migration "Consolidated from dev/repl/init.clj + dev/repl/session.clj (2025-10-17)"
  :docs-ref "CLAUDE.md#dev-tooling"}

 ;; === Configuration ===
 :config
 {:mcp-config ".mcp.json"
  :claude-config "~/.claude.json"
  :env-file ".env"
  :project-docs "CLAUDE.md"
  :api-keys-required ["GEMINI_API_KEY" "OPENAI_API_KEY" "XAI_API_KEY"]}

