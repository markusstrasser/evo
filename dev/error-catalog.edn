{:categories
 {:build-failure
  {:signals ["shadow-cljs.*failed"
             "Compilation failed"
             "Build failure"
             "Cannot find module"]
   :remedies ["Check shadow-cljs.edn for typos"
              "Verify all deps in deps.edn"
              "Clear cache: npm run clean"
              "Restart shadow-cljs: npm run dev"]}
  
  :namespace-not-found
  {:signals ["No such namespace"
             "Could not require"
             "cljs.analyzer.*resolve.*not found"
             "Namespace.*does not exist"]
   :remedies ["Check namespace declaration matches file path"
              "Verify deps.edn :paths includes parent directory"
              "Check for circular requires"
              "Restart REPL and reconnect"]}
  
  :test-timeout
  {:signals ["Execution timed out"
             "Test.*timeout"
             "Process.*timed out"]
   :remedies ["Check for infinite loops in test code"
              "Increase timeout in shadow-cljs.edn"
              "Look for blocking I/O or promises"
              "Check test fixtures for resource leaks"]}
  
  :cache-corruption
  {:signals ["ClassCastException"
             "AbstractMethodError"
             "Stale compilation"
             "Inconsistent.*cache"]
   :remedies ["Nuclear option: npm run clean"
              "Clear shadow-cljs cache: rm -rf .shadow-cljs"
              "Clear node modules: rm -rf node_modules && npm install"
              "Check for multiple shadow-cljs versions"]}
  
  :port-conflict
  {:signals ["EADDRINUSE"
             "Address already in use"
             "Port.*already.*bound"]
   :remedies ["Kill process on port 8080: lsof -ti :8080 | xargs kill"
              "Kill process on port 7888: lsof -ti :7888 | xargs kill"
              "Check for zombie shadow-cljs: pkill -f shadow-cljs"]}
  
  :reader-conditional-error
  {:signals ["Reader conditional.*not.*allowed"
             "Conditional read not allowed"
             "#\\?.*not.*allowed"]
   :remedies ["Check file extension: .cljc for cross-platform code"
              "Verify reader conditionals use #? or #?@"
              "Check for bare js/ refs in .cljc files"]}
  
  :macro-expansion-error
  {:signals ["Unable to resolve symbol.*in this context"
             "Macros.*cannot be.*used as functions"
             "Can't take value of a macro"]
   :remedies ["Check if requiring macro namespace with :require-macros"
              "Verify macro is defined before use"
              "Check for circular macro dependencies"
              "Use fully qualified symbols in macro-generated code"]}
  
  :repl-disconnect
  {:signals ["nREPL.*closed"
             "Connection refused.*7888"
             "REPL.*not connected"]
   :remedies ["Restart nREPL: npm run mcp"
              "Check nREPL port in deps.edn matches client"
              "Verify JVM process is running: jps | grep nrepl"
              "Check firewall blocking port 7888"]}
  
  :linting-failure
  {:signals ["clj-kondo.*error"
             "Unresolved symbol"
             "Unused.*namespace"]
   :remedies ["Review clj-kondo output for details"
              "Add namespace to :lint-as config if legitimate"
              "Check for typos in symbol names"
              "Update .clj-kondo/config.edn exclusions"]}}
 
 :patterns
 {:extract-error-type
  {:regex "(?i)(error|exception|failure|timeout|not found)"
   :priority [:signals :remedies]}
  
  :extract-namespace
  {:regex "([a-z][a-z0-9-]*\\.)+[a-z][a-z0-9-]*"
   :context :namespace-not-found}
  
  :extract-port
  {:regex ":\\d{4,5}"
   :context :port-conflict}}}