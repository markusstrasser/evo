   :fix "Remove from keymap OR component, not both"
   :lesson "Single event should have single handler"
   :prevention "Keymap conflict linter"
   :example "Enter bound in :editing keymap AND Block :on-keydown"}]

 :mental-models
 [{:model "replicant-lifecycle"
   :description "How Replicant manages DOM updates and lifecycle"
   :diagram "Component fn (fresh args) → Hiccup → Replicant diff → DOM update (reuse nodes) → Lifecycle hooks (reused fns!) → :remember WeakMap"
   :key-insights
   ["Component function called with fresh args each render"
    "Hiccup diffed, DOM nodes reused where :key matches"
    "Lifecycle hooks REUSED across renders"
    "Hooks close over component scope → STALE on re-render"
    ":remember uses WeakMap(node → data) to store fresh values"
    "WeakMap cleared when node unmounted"]
   :when-useful "Debugging lifecycle-related bugs, stale closures"
   :verified true}

  {:model "contenteditable-cursor-management"
   :description "Why cursor is hard and how to handle it"
   :key-insights
   ["Browser owns cursor position (not in virtual DOM)"
    "Setting textContent destroys cursor position"
    "Can't reliably control cursor from framework"
    "Empty text creates zero child nodes (special case)"
    "Focus required ALWAYS, cursor positioning optional"
    "Uncontrolled pattern = set once, browser manages"]
   :when-useful "Any contenteditable debugging"
   :verified true}]

