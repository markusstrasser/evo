 :patterns-learned
 [{:pattern-id "uncontrolled-contenteditable"
   :when "Rich text editing with inline formatting"
   :why "Browser owns cursor state, frameworks can't reliably control it"
   :approach "Set content once via lifecycle hook, browser manages after"
   :tools [":replicant/remember" ":replicant/on-render"]
   :pitfalls
   [{:name "stale-closures"
     :description "Hooks reuse function, capture old vars"
     :solution ":remember to get fresh data per node"}
    {:name "empty-blocks-no-text-node"
     :description "textContent='' creates zero nodes"
     :solution "Test empty and non-empty separately"}
    {:name "conditional-focus"
     :description "Focus inside text-node check fails for empty"
     :solution "Focus must always happen, unconditionally"}]
   :tests ["cursor-preservation" "focus-attachment" "db-dom-match" "empty-blocks"]
   :industry-standard true
   :used-by ["React" "Notion" "Logseq" "Roam"]
   :alternatives ["textarea (no rich text)" "Draft.js (heavy)" "ProseMirror (complex)"]
   :resources ["docs/RENDERING_AND_DISPATCH.md" "docs/CONTENTEDITABLE_DEBUGGING.md"]}

  {:pattern-id "duplicate-event-dispatch"
   :when "Same key bound in multiple places"
