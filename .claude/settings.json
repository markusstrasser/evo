{
  "skillOverrides": {
    "scientific-drawing": "off",
    "skill-creator:skill-creator": "off",
    "security-review": "off",
    "life-science-research": "off",
    "modal": "off",
    "claude-api": "off",
    "skill-authoring": "off",
    "playground:playground": "off",
    "keybindings-help": "off"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "PROTECTED_PATHS='resources/specs\\.edn|resources/failure_modes\\.edn|tests/fixtures/golden_' BLOCK_MSG='BLOCKED: Cannot modify specs.edn, failure_modes.edn, or golden fixtures without human approval.' ~/Projects/skills/hooks/pretool-data-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/alien/Projects/skills/hooks/postcommit-doc-staleness.sh",
            "statusMessage": "Checking doc propagation..."
          }
        ]
      }
    ]
  }
}
