{:format-version 1
 :last-updated "2025-11-27"
 :description "Database of known failure modes with symptoms, causes, and fixes"

 :modes
 {:cursor-reset
  {:name "Cursor Resets to Position 0"
   :severity :high
   :symptoms
   ["Typing 'abc' produces 'cba'"
    "Characters appear in reverse order"
    "Cursor always at position 0 after typing"
    "Text correct but cursor position wrong"]
   :root-causes
   ["Setting textContent on every render (controlled component)"
    "Declarative text child in contenteditable [:span text]"
    "Re-rendering contenteditable without cursor preservation"]
   :detection
   ["Type 'abc' → check text === 'abc' not 'cba'"
    "Monitor cursor position: should increase, not reset to 0"
    "Browser console: window.getSelection().getRangeAt(0).startOffset"]
   :fixes
   [":replicant/remember to set textContent ONCE"
    "Uncontrolled pattern: set content once, browser manages"
    "Never use declarative text child in contenteditable"]
   :tests
   ["Type 3+ characters, verify order preserved"
    "Property test: cursor always increases"
    "After typing N chars, cursor at position N"]
   :prevention
   "Lint [:span.content-edit text] pattern - should use lifecycle hook"
   :related [:stale-closure :declarative-anti-pattern]
   :verified true
   :example-fix "src/components/block.cljs:537 - use :replicant/remember"}

  :focus-not-attached
  {:name "Focus Doesn't Attach After Navigation"
   :severity :critical
   :symptoms
   ["Must click before typing (breaks keyboard flow)"
    "document.activeElement === document.body"
    "Pressing keys after Enter does nothing"
    "Can't type immediately after creating block"]
   :root-causes
   ["`.focus node` inside conditional that fails"
    "Empty blocks have no text node → condition fails"
    "Focus call missing entirely"
    "Focus called too early (before DOM update)"]
   :detection
   ["After Enter, check: document.activeElement.contentEditable === 'true'"
    "Try typing immediately without clicking"
    "Browser console: document.activeElement.tagName (should be SPAN not BODY)"]
   :fixes
   ["Move .focus OUTSIDE conditionals - must always happen"
    "Focus is required side effect, not optional"
    "Call .focus after DOM update in lifecycle hook"]
   :tests
   ["After Enter, typing works without click"
    "document.activeElement === contenteditable element"
    "Focus works for both empty and non-empty blocks"]
   :prevention
   "Lint .focus inside when/if blocks - warn it should be unconditional"
   :special-cases
   ["Empty blocks (no text node) hit different code path"
    "Must test empty separately from non-empty"]
   :related [:empty-block-special-case]
   :verified true
   :example-fix "src/components/block.cljs:571 - unconditional .focus"}

  :stale-closure
  {:name "Stale Closure in Lifecycle Hook"
   :severity :high
   :symptoms
   ["Wrong text in contenteditable"
    "DB text doesn't match DOM text"
    "Empty block shows text from different block"
    "Old values appear after update"]
   :root-causes
   ["Lifecycle hook closes over component scope"
    "Hook function reused across renders"
    "Captured `text` or `db` from original render"
    "Reading closure vars instead of fresh args"]
   :detection
   ["Compare DB vs DOM: (= db-text dom-text)"
    "After operation, check textContent matches DB"
    "Browser console: DEBUG.compareDBvsDOM(block-id)"]
   :fixes
   [":replicant/remember with fresh data from component args"
    "Pass data via node dataset, not closures"
    "Use :remember to store per-node state"]
   :tests
   ["After any operation, DB text === DOM text"
    "Create empty block, verify textContent === ''"
    "Property test: DB/DOM always match"]
   :prevention
   "Lint lifecycle hooks reading closure vars - warn to use :remember"
   :why-happens
   "Hooks reused → close over OLD component scope → see STALE vars"
   :related [:cursor-reset :empty-block-special-case]
   :verified true
   :example-fix "src/components/block.cljs:537 - :replicant/remember"}

  :duplicate-event-dispatch
  {:name "Duplicate Event Dispatch"
   :severity :high
   :symptoms
   ["Operation fires twice per keypress"
    "Count operations → 2 instead of 1"
    "Logs show duplicate :context-aware-enter"
    "Unexpected behavior from single keypress"]
   :root-causes
   ["Same key bound in keymap AND component :on-keydown"
    "Multiple event handlers for same key"
    "Event bubbles through multiple handlers"]
   :detection
   ["Count operations after keypress"
    "Check operations log for duplicates"
    "Browser console: DEBUG.getOperations().slice(-5)"]
   :fixes
   ["Remove from keymap OR component, not both"
    "Use stopPropagation if both needed"
    "Prefer component handlers for editing keys"]
   :tests
   ["Press Enter once → exactly 1 operation"
    "No duplicate operations within 100ms"
    "Property test: 1 keypress → 1 operation"]
   :prevention
   "Keymap conflict checker - lint same key in multiple places"
   :related []
   :verified true
   :example-fix "src/keymap/bindings_data.cljc:27 - removed Enter from keymap"}

  :empty-block-special-case
  {:name "Empty Blocks Hit Different Code Path"
   :severity :medium
   :symptoms
   ["Bug appears only for empty blocks, not text blocks"
    "textContent === '' behaves differently"
    "Conditional on text-node fails"]
   :root-causes
   ["Empty text creates ZERO child nodes"
    "firstChild === null for empty contenteditable"
    "Code checks (when text-node ...) → fails for empty"]
   :detection
   ["Test empty blocks separately"
    "Check editable.firstChild after setting textContent=''"
    "Browser console: editable.childNodes.length === 0"]
   :fixes
   ["Test both empty and non-empty explicitly"
    "Don't assume text-node exists"
    "Handle null case explicitly"]
   :tests
   ["Create empty block, verify behavior"
    "Property test with empty string edge case"
    "Both '' and 'text' should work"]
   :prevention
   "Always test edge cases: ['', 'a', 'long text...']"
   :related [:focus-not-attached :stale-closure]
   :verified true
   :example-impact "Empty blocks couldn't get focus due to missing text node"}

  :declarative-anti-pattern
  {:name "Declarative Text Child in contenteditable"
   :severity :high
   :symptoms
   ["Cursor resets while typing"
   "Text updates but cursor at position 0"
   "Re-renders destroy cursor position"]
   :root-causes
   ["[:span.content-edit text] passes text as child"
    "Replicant re-renders on text change"
    "Browser resets cursor when DOM updated"]
   :detection
   ["Grep for [:span.content-edit text]"
    "Check if text passed as direct child"
    "Cursor resets → likely controlled component"]
   :fixes
   ["Use :replicant/on-render lifecycle hook"
    "Set textContent via side effect, not declaratively"
    "Uncontrolled pattern: [:span {:replicant/on-render ...}]"]
   :tests
   ["Type 'abc' → order preserved"
    "Cursor position increases"
    "No re-render during typing"]
   :prevention
   "Lint declarative text in contenteditable elements"
   :related [:cursor-reset]
   :verified true
   :example-fix "src/components/block.cljs:598 - removed declarative text"}

  :keyboard-event-not-triggering
  {:name "Keyboard Events Don't Trigger Replicant Handlers on Contenteditable"
   :severity :high
   :symptoms
   ["Pressing Backspace at position 0 doesn't merge blocks"
    "Keyboard shortcuts work in non-editing mode but not while editing"
    "E2E tests pass with dispatchIntent but fail with page.keyboard.press()"
    "defaultPrevented stays false throughout event lifecycle"]
   :root-causes
   ["Playwright keyboard events may not properly interact with Replicant's event delegation"
    "Replicant attaches handlers via addEventListener but synthetic events may bypass"
    "Event reaches DOM but Replicant's internal dispatch never fires"
    "Gap between E2E test coverage and real keyboard interaction"]
   :detection
   ["Add capturing listener: document.addEventListener('keydown', e => console.log(e.defaultPrevented), {capture: true})"
    "If defaultPrevented stays false, handler never called .preventDefault()"
    "Compare: dispatchIntent works but keyboard.press() doesn't"]
   :fixes
   ["Use TEST_HELPERS.dispatchIntent() in E2E tests (workaround)"
    "Investigate Replicant's internal event capture mechanism"
    "Consider adding global keydown handler as fallback for contenteditable"]
   :tests
   ["Manual browser test: click block, press Backspace at start"
    "Compare unit test results with actual browser behavior"
    "Log in handle-keydown to verify if it's being called"]
   :prevention
   "Document limitation in REPLICANT_TESTING.md - E2E tests have coverage gap"
   :testing-implications
   ["Unit tests verify intent handlers work"
    "dispatchIntent E2E tests verify DOM updates"
    "Keyboard→intent binding is NOT tested by current test suite"]
   :related [:duplicate-event-dispatch]
   :verified true
   :investigation-date "2025-11-27"
   :example-workaround "test/e2e/critical-fixes.spec.js - uses dispatchIntent instead of keyboard"}}}
