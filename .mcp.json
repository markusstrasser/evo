{
  "mcpServers": {
    "mcp-shadow-dual": {
      "type": "local",
      "enabled": true,
      "command": "/opt/homebrew/bin/bash",
      "args": [
        "-c",
        "clojure -X:mcp-shadow-dual"
      ]
    },
    "tournament": {
      "type": "local",
      "enabled": true,
      "command": "uv",
      "args": [
        "--directory",
        "/Users/alien/Projects/tournament-mcp",
        "run",
        "python",
        "eval_server.py"
      ],
      "env": {
        "OPENAI_API_KEY": "${OPENAI_API_KEY}",
        "GOOGLE_API_KEY": "${GOOGLE_API_KEY}",
        "XAI_API_KEY": "${XAI_API_KEY}",
        "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}"
      }
    },
    "context7": {
      "type": "local",
      "enabled": true,
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "exa": {
      "type": "http",
      "enabled": true,
      "url": "https://mcp.exa.ai/mcp",
      "headers": {}
    },
    "computer-use": {
      "type": "local",
      "enabled": true,
      "command": "uv",
      "args": [
        "run",
        "--project",
        "/Users/alien/Projects/computer-use-mcp",
        "--with",
        "fastmcp",
        "fastmcp",
        "run",
        "/Users/alien/Projects/computer-use-mcp/computer_use_mcp_server.py"
      ]
    }
  }
}