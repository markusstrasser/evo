{
  "mcpServers": {
    "mcp-shadow-dual": {
      "type": "stdio",
      "command": "/opt/homebrew/bin/bash",
      "args": [
        "-c",
        "clojure -X:mcp-shadow-dual"
      ]
    },
    "tournament": {
      "type": "stdio",
      "command": "uv",
      "args": [
        "--directory",
        "/Users/alien/Projects/tournament-mcp",
        "run",
        "eval_server.py"
      ],
      "env": {
        "OPENAI_API_KEY": "${OPENAI_API_KEY}",
        "GOOGLE_API_KEY": "${GOOGLE_API_KEY}",
        "GROQ_API_KEY": "${GROQ_API_KEY}",
        "ANTHROPIC_API_KEY": "${ANTHROPIC_API_KEY}"
      }
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ]
    },
    "exa": {
      "type": "http",
      "url": "https://mcp.exa.ai/mcp?exaApiKey=bc29396d-741a-463a-b1e8-a947e26cf532&tools=web_search_exa,web_search_advanced_exa,crawling_exa,company_research_exa,people_search_exa,deep_researcher_start,deep_researcher_check"
    },
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": ["chrome-devtools-mcp@latest"]
    }
  }
}
