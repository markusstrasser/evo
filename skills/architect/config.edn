{:skill-meta
 {:name "Architectural Proposals & ADR Workflow"
  :version "1.0.0"
  :type :workflow
  :triggers ["propose" "architecture" "adr" "design decision" "review" "tournament"]
  :network-required true  ; Calls LLM CLIs
  :dependencies ["gemini" "codex" "llmx" "tournament-mcp"]}

 :llm-providers
 {:gemini {:command "gemini"
           :default-model "gemini-2.5-pro"  ; CRITICAL: Never use flash for architectural decisions
           :session-support true}
  :codex {:command "codex"
          :default-model "gpt-5-codex"     ; CRITICAL: Always use gpt-5 with high reasoning
          :reasoning-effort "high"         ; REQUIRED: Maximum reasoning for architecture
          :session-support true}
  :grok {:command "llmx"
         :provider "xai"
         :default-model "grok-4-latest"}}

 :tournament
 {:mcp-server "tournament-mcp"
  :default-judges ["gpt5-codex" "gemini25-pro" "grok-4"]
  :max-rounds 3
  :confidence-threshold 0.85}

 :workflow
 {:proposal-count 3
  :auto-decide false          ; Require human approval by default
  :refine-max-rounds 5}

 :evaluation-criteria
 {:priorities
  ["Simplicity (HIGHEST) - Solo dev can understand/debug"
   "Debuggability - Observable state, clear errors"
   "Flexibility - Can skip stages, run tools independently"
   "Provenance - Trace proposal → spec → implementation"
   "Quality gates - Catch bad specs early"]

  :red-flags
  ["Infinite refinement loops"
   "Hidden automation"
   "Complex orchestration"
   "Tight coupling"
   "Over-engineering"]}

 :storage
 {:review-runs ".architect/review-runs/"
  :adr ".architect/adr/"
  :ledger ".architect/review-ledger.jsonl"
  :specs ".architect/specs/"}

 :templates
 {:adr "data/templates/adr-template.md"
  :spec "data/templates/spec-template.md"}

 ;; CRITICAL MODEL POLICY
 :model-policy
 {:rationale "Architectural decisions require maximum reasoning capability"
  :never-use ["gpt-4o" "gpt-4-turbo" "gemini-flash" "gemini-1.5-*"]
  :always-use ["gpt-5-codex" "gemini-2.5-pro" "grok-4-latest"]
  :reasoning-effort "high"  ; Non-negotiable for architecture work
  :cost-justification "Token savings from progressive disclosure far exceed model costs"}}
