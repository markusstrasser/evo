;; Common GPT-5 prompting pitfalls and fixes

{:contradictory-instructions
 {:description "GPT-5 wastes reasoning tokens reconciling conflicts"
  :examples
  [{:bad "Prefer standard library, but use external packages if simpler"
    :good "Use only Python stdlib. No external dependencies."
    :reason "Removes ambiguity about package usage"}

   {:bad "Single-pass streaming, but reread or cache if clearer"
    :good "Single-pass streaming only. No rereading or caching."
    :reason "Eliminates conflicting memory constraints"}

   {:bad "Exact results, but approximate methods are fine"
    :good "Exact Top-K only. No approximations or sketches."
    :reason "Clear requirement for precision"}

   {:bad "Never schedule without consent\nAuto-assign earliest slot without contacting"
    :good "Auto-assign after informing patient of actions"
    :reason "Resolves consent contradiction"}]

  :fix-strategy
  ["Identify conflicting statements"
   "Choose one approach as hard requirement"
   "Remove or clarify soft preferences"
   "Test prompt for internal consistency"]}

 :missing-instruction-hierarchy
 {:description "All instructions sound equally important"
  :examples
  [{:bad "Use readable names\nAvoid file I/O\nPrefer comments\nNo approximations"
    :good "# MUST (hard requirements)\n- No file I/O\n- No approximations\n\n# SHOULD (preferences)\n- Prefer readable names\n- Add comments where helpful"
    :reason "Separates critical constraints from style preferences"}]

  :fix-strategy
  ["Use MUST vs SHOULD sections"
   "Order by importance"
   "Mark hard requirements clearly"
   "Allow soft preferences to flex"]}

 :low-reasoning-on-hard-tasks
 {:description "Using minimal/medium reasoning for complex decisions"
  :examples
  [{:bad {:reasoning "minimal"
          :task "Compare event sourcing vs CQRS"}
    :good {:reasoning "high"
           :task "Compare event sourcing vs CQRS"}
    :reason "Architecture decisions require deep deliberation"}

   {:bad {:reasoning "medium"
          :task "Review code for maintainability"}
    :good {:reasoning "high"
           :task "Review code for maintainability"}
    :reason "Code review requires taste and judgment"}]

  :fix-strategy
  ["Use high for architecture/taste/review (ALWAYS)"
   "Use minimal only for deterministic tasks"
   "When unsure, default to medium first"
   "Profile task complexity before choosing effort"]}

 :verbose-noise
 {:description "Excessive verbosity cluttering outputs"
  :examples
  [{:bad {:verbosity "high"
          :context "Status updates"}
    :good {:verbosity "low"
           :context "Status updates"}
    :reason "Status updates should be terse"}

   {:bad {:verbosity "low"
          :context "Code generation"}
    :good {:verbosity "high"
           :context "Code generation"}
    :reason "Code should be readable and well-explained"}]

  :cursor-pattern
  {:global {:verbosity "low"}
   :override "Use high verbosity for writing code and code tools"
   :result "Terse status updates, verbose code diffs"}}

 :cli-vs-api
 {:description "Using CLI when API would be better"
  :when-to-use-cli
  ["Interactive exploration (REPL-like sessions)"
   "Legacy scripts not yet migrated"
   "Session continuity needed (codex --resume)"]

  :when-to-use-api
  ["Building agents or automation"
   "Need structured outputs (PydanticAI)"
   "Production workflows"
   "Type safety and validation matter"]

  :common-cli-mistakes
  [{:mistake "codex -p \"prompt\" -"
    :fix "echo \"prompt\" | codex exec --full-auto -"
    :reason "Batch mode requires exec --full-auto"}

   {:mistake "Not setting model_reasoning_effort"
    :fix "codex -c model_reasoning_effort=\"high\""
    :reason "Taste questions need high reasoning"}

   {:mistake "Using CLI in production"
    :fix "Migrate to API with OpenAI SDK or PydanticAI"
    :reason "API is more reliable and type-safe"}]}

 :premature-termination
 {:description "Agent stops before task complete"
  :causes
  ["Missing persistence instructions"
   "Unclear stop conditions"
   "Eagerness set too low"]

  :fixes
  [{:add "<persistence>\n- Keep going until completely resolved\n- Only terminate when problem solved\n</persistence>"}
   {:add "# Stop conditions\n- All sub-requests completed\n- All tests passing"}
   {:set {:reasoning_effort "high"}}]}}
