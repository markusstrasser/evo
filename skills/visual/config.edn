{:skill-meta
 {:name "Visual Validation Toolkit"
  :version "1.0.0"
  :triggers ["visual" "canvas" "webgl" "validate" "compare" "analyze"]
  :network-required false
  :dependencies ["python3" "opencv-python" "numpy" "pillow"]}

 :analysis
 {:wave-detection
  {:threshold 0.5
   :min-ring-count 5
   :max-ring-count 50
   :spacing-tolerance 0.10}

  :lighting
  {:brightness-tolerance 0.05
   :contrast-tolerance 0.10
   :shadow-threshold 0.15}

  :geometry
  {:position-tolerance 2.0
   :size-tolerance 0.05
   :angle-tolerance 1.0}}

 :comparison
 {:fail-threshold 0.15
  :warn-threshold 0.05
  :pass-threshold 0.02
  :output-format :text}

 :output-formats
 {:text {:show-emoji true
         :show-percentage true
         :show-fixes true}
  :json {:pretty true
         :include-metadata true}
  :markdown {:include-summary true
             :include-details true}
  :yaml {:indent 2}}

 :paths
 {:python-scripts "../../scripts/"
  :cache-dir ".cache/visual/"
  :test-references "data/test-references/"
  :test-outputs "data/test-outputs/"}

 :python-env
 {:required-packages ["opencv-python" "numpy" "pillow"]
   :optional-packages ["matplotlib" "scipy"]
   :min-python-version "3.7"}}
