{:skill-meta
 {:name "Research Best-Of Repositories"
  :version "1.0.0"
  :triggers ["research" "best-of" "reference" "patterns" "inspiration"]
  :network-required true
  :dependencies ["repomix" "gemini" "codex"]}

 :model-selection
 {:gemini {:use-for ["high-token-count" "large-repos" "multi-file" "sessions"]
           :default-model "gemini-2.5-pro"  ; CRITICAL: Never use flash for Skills work
           :cost :medium  ; Worth it for quality
           :speed :medium}
  :codex {:use-for ["code-review" "architecture" "taste" "refactoring"]
          :default-model "gpt-5-codex"
          :default-config {:model_reasoning_effort "high"}
          :cost :high
          :speed :slow}
  :grok {:use-for ["quick-queries" "fallback"]
         :default-model "grok-4-latest"
         :cost :medium
         :speed :medium}

  ;; CRITICAL MODEL POLICY
  :policy {:never-use ["gpt-4o" "gpt-4-turbo" "gemini-flash" "gemini-1.5-*"]
           :always-use ["gpt-5-codex" "gemini-2.5-pro" "grok-4-latest"]
           :reasoning-effort "high"
           :rationale "Skills are for important work - token savings from progressive disclosure >> model costs"}}

 :common-queries
 {:event-sourcing
  {:query "How is event sourcing implemented? Show the event log structure, transaction handling, and replay mechanisms."
   :relevant-projects ["datascript" "datalevin" "electric"]}

  :reactive-state
  {:query "How is reactive state managed? Show subscription patterns, state propagation, and performance optimizations."
   :relevant-projects ["re-frame" "electric" "javelin" "reagent"]}

  :macro-patterns
  {:query "What are the common macro patterns? Show examples of code generation, compile-time optimization, and DSL implementation."
   :relevant-projects ["clojurescript" "core.async" "specter"]}

  :api-design
  {:query "How are APIs designed for composability? Show function composition, middleware patterns, and extension points."
   :relevant-projects ["ring" "compojure" "reitit" "pathom3"]}

  :test-patterns
  {:query "What testing patterns are used? Show test organization, fixture management, and property-based testing."
   :relevant-projects ["clojure" "datascript" "malli"]}

  :build-workflow
  {:query "How is the build workflow organized? Show compilation, optimization, and development hot-reload setup."
   :relevant-projects ["shadow-cljs" "clerk" "clojurescript"]}}

 :size-thresholds
 {:small-repo-mb 10   ; Full src extraction
  :large-repo-mb 50   ; Require focused paths
  :huge-repo-mb 200}  ; Multiple focused queries recommended

 :paths
 {:best-repos "${HOME}/Projects/best"
  :repos-data "./data/repos.edn"
  :cache-dir ".cache/research"}

 :timeouts
 {:repomix-sec 30
  :llm-query-sec 120
  :session-max-min 60}}
