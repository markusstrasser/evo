#!/bin/bash
# Pre-commit hook: Quality checks and file syncing

set -e  # Exit on first error

# ── Check for shadowed core vars ─────────────────────────────────────────────

# Only check Clojure/ClojureScript files being committed
CLOJURE_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(clj|cljs|cljc)$' || true)

if [ -n "$CLOJURE_FILES" ]; then
    echo "🔍 Checking for shadowed variables..."

    # Run linter and check for shadowed var warnings
    if bb lint 2>&1 | grep -q "Shadowed var:"; then
        echo ""
        echo "❌ Shadowed core variables detected!"
        echo ""
        echo "Fix by renaming variables to avoid shadowing clojure.core:"
        echo "  • char → input-char, character"
        echo "  • count → total-count, num-items"
        echo "  • num → number, value"
        echo "  • name → var-name, identifier"
        echo ""
        echo "See docs/CODING_GOTCHAS.md for details."
        echo ""
        echo "To bypass this check: git commit --no-verify"
        exit 1
    fi

    echo "✓ No shadowed variables found"
fi

# ── Check E2E tests for risky keyboard usage ─────────────────────────────────

# Only check E2E test files being committed
E2E_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E 'test/e2e/.*\.spec\.js$' || true)

if [ -n "$E2E_FILES" ]; then
    echo "🔍 Checking E2E tests for keyboard event issues..."

    # Create temp file with just the staged content
    TEMP_DIR=$(mktemp -d)
    trap "rm -rf $TEMP_DIR" EXIT

    HAS_ISSUES=false
    for file in $E2E_FILES; do
        # Get staged content
        git show ":$file" > "$TEMP_DIR/$(basename $file)"

        # Check for problematic keyboard usage
        if grep -nE "page\.keyboard\.press\(['\"]+(ArrowLeft|ArrowRight|ArrowUp|ArrowDown|Enter|Backspace|Delete|Tab)" "$TEMP_DIR/$(basename $file)" > /dev/null; then
            if [ "$HAS_ISSUES" = false ]; then
                echo ""
                echo "❌ Found page.keyboard.press() calls on risky keys in modified E2E tests!"
                echo ""
                HAS_ISSUES=true
            fi

            echo "  File: $file"
            grep -nE "page\.keyboard\.press\(['\"]+(ArrowLeft|ArrowRight|ArrowUp|ArrowDown|Enter|Backspace|Delete|Tab)" "$TEMP_DIR/$(basename $file)" | head -3
            echo ""
        fi
    done

    if [ "$HAS_ISSUES" = true ]; then
        echo "💡 Solutions:"
        echo "  • For navigation testing: Use pressKeyOnContentEditable() from test/e2e/helpers/keyboard.js"
        echo "  • For test setup: Dispatch intents directly via window.DEBUG.handleIntent()"
        echo ""
        echo "See docs/TESTING.md for details."
        echo ""
        echo "To bypass this check: git commit --no-verify"
        echo ""
        exit 1
    fi

    echo "✓ No keyboard event issues in modified E2E tests"
fi

# ── Sync CLAUDE.md to AGENTS.md ──────────────────────────────────────────────
# DISABLED: CLAUDE.md was removed due to repo bloat (10GB transcript file)

# if git diff --cached --name-only | grep -q "^CLAUDE.md$"; then
#     echo "🔄 Syncing CLAUDE.md → AGENTS.md..."
#
#     # Create AGENTS.md with warning header + CLAUDE.md content
#     {
#         echo "<!-- WARNING: DO NOT EDIT THIS FILE DIRECTLY!"
#         echo "This file is automatically generated from CLAUDE.md via git pre-commit hook."
#         echo "Any changes made here will be overwritten. Edit CLAUDE.md instead. -->"
#         echo ""
#         cat CLAUDE.md
#     } > AGENTS.md
#
#     # Stage AGENTS.md for commit
#     git add AGENTS.md
#
#     echo "✓ AGENTS.md updated and staged"
# fi

exit 0
