#!/bin/bash
# Pre-commit hook: Quality checks on staged files
#
# Checks (only on staged files):
# 1. Shadowed core vars (Clojure/ClojureScript)
# 2. E2E keyboard usage anti-patterns (Playwright)
# 3. Namespace/path consistency (dev/, mcp/ classpath roots)
# 4. Missing goog.string.format import

set -e  # Exit on first error

# ── Check for shadowed core vars ─────────────────────────────────────────────

CLOJURE_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(clj|cljs|cljc)$' || true)

if [ -n "$CLOJURE_FILES" ]; then
    echo "🔍 Checking for shadowed variables..."

    if bb lint 2>&1 | grep -q "Shadowed var:"; then
        echo ""
        echo "❌ Shadowed core variables detected!"
        echo ""
        echo "Fix by renaming variables to avoid shadowing clojure.core:"
        echo "  • char → input-char, character"
        echo "  • count → total-count, num-items"
        echo "  • num → number, value"
        echo "  • name → var-name, identifier"
        echo ""
        echo "See docs/CODING_GOTCHAS.md for details."
        exit 1
    fi

    echo "✓ No shadowed variables found"
fi

# ── Check E2E tests for risky keyboard usage ─────────────────────────────────

E2E_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E 'test/e2e/.*\.spec\.js$' || true)

if [ -n "$E2E_FILES" ]; then
    echo "🔍 Checking E2E tests for keyboard event issues..."

    TEMP_DIR=$(mktemp -d)
    trap "rm -rf $TEMP_DIR" EXIT

    HAS_ISSUES=false
    for file in $E2E_FILES; do
        git show ":$file" > "$TEMP_DIR/$(basename $file)"

        if grep -nE "page\.keyboard\.press\(['\"]+(ArrowLeft|ArrowRight|ArrowUp|ArrowDown|Enter|Backspace|Delete|Tab)" "$TEMP_DIR/$(basename $file)" > /dev/null; then
            if [ "$HAS_ISSUES" = false ]; then
                echo ""
                echo "❌ Found page.keyboard.press() calls on risky keys in modified E2E tests!"
                echo ""
                HAS_ISSUES=true
            fi

            echo "  File: $file"
            grep -nE "page\.keyboard\.press\(['\"]+(ArrowLeft|ArrowRight|ArrowUp|ArrowDown|Enter|Backspace|Delete|Tab)" "$TEMP_DIR/$(basename $file)" | head -3
            echo ""
        fi
    done

    if [ "$HAS_ISSUES" = true ]; then
        echo "💡 Use pressKeyOnContentEditable() from test/e2e/helpers/keyboard.js"
        echo "   See docs/TESTING.md for details."
        exit 1
    fi

    echo "✓ No keyboard event issues in modified E2E tests"
fi

# ── Check namespace/path consistency ─────────────────────────────────────────

if [ -n "$CLOJURE_FILES" ]; then
    echo "🔍 Checking namespace/path consistency..."

    # dev/ classpath root: files in dev/repl/ should use ns repl.*, not dev.repl.*
    for file in $(echo "$CLOJURE_FILES" | grep '^dev/repl/' || true); do
        ns_decl=$(grep -m1 "^(ns " "$file" 2>/dev/null | sed 's/(ns //' | awk '{print $1}')
        if [[ "$ns_decl" == dev.repl.* ]]; then
            echo "❌ Wrong namespace in $file: $ns_decl"
            echo "   With 'dev' on classpath, use namespace 'repl.*', not 'dev.repl.*'"
            exit 1
        fi
    done

    # mcp/ classpath root: files in mcp/servers/ should use ns servers.*, not mcp.servers.*
    for file in $(echo "$CLOJURE_FILES" | grep '^mcp/servers/' || true); do
        ns_decl=$(grep -m1 "^(ns " "$file" 2>/dev/null | sed 's/(ns //' | awk '{print $1}')
        if [[ "$ns_decl" == mcp.servers.* ]]; then
            echo "❌ Wrong namespace in $file: $ns_decl"
            echo "   With 'mcp' on classpath, use namespace 'servers.*', not 'mcp.servers.*'"
            exit 1
        fi
    done

    # Check for gstr/format without goog.string.format import
    if grep -l "gstr/format" $CLOJURE_FILES 2>/dev/null | head -1 | grep -q .; then
        if ! grep -l "goog.string.format" $CLOJURE_FILES 2>/dev/null | head -1 | grep -q .; then
            echo "❌ Found gstr/format usage without goog.string.format import"
            echo "   Add: #?(:cljs [goog.string.format]) to namespace requires"
            exit 1
        fi
    fi

    echo "✓ Namespace/path checks passed"
fi

exit 0
