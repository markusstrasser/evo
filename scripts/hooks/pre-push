#!/usr/bin/env bash
# Git pre-push hook.
#
# Overview generation used to run on every push, which made the hot path noisy
# and slow for trivial commits. Keep pushes fast by default.
#
# Opt in when wanted:
#   EVO_GENERATE_OVERVIEWS_ON_PUSH=1 git push

if [ "${EVO_GENERATE_OVERVIEWS_ON_PUSH:-0}" != "1" ]; then
  exit 0
fi

echo "📦 Generating all overviews (source, project, dev)..."
./scripts/generate-overview.sh --auto

if [ -f "dev/overviews/AUTO-SOURCE-OVERVIEW.md" ] || \
   [ -f "dev/overviews/AUTO-PROJECT-OVERVIEW.md" ] || \
   [ -f "dev/overviews/AUTO-DEV-OVERVIEW.md" ]; then
  echo "✅ Overviews generated successfully"
else
  echo "⚠️  Warning: Overviews may not have been generated"
fi

exit 0
