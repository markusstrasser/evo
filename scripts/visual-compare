#!/usr/bin/env bb

(require '[clojure.string :as str]
         '[clojure.java.shell :as shell]
         '[babashka.fs :as fs])

(def help-text
  "Visual Compare - Programmatic image comparison with normalization

Usage:
  visual-compare <reference> <implementation> [options]

Options:
  -o, --output <dir>   Output directory (default: /tmp/visual-compare/)
  --normalize          Resize and crop both to same dimensions before comparing
  --threshold <n>      Difference threshold % (0-100, default: 10)
  -h, --help           Show this help

Output:
  - diff.png           Visual difference highlighting
  - metrics.txt        RMSE, pixel difference count, percentage
  - normalized/        Normalized versions if --normalize used

Approach:
  1. Extract bounding boxes of main content using edge detection
  2. Crop both images to content only
  3. Resize to same dimensions
  4. Run ImageMagick compare with metrics
  5. Generate annotated diff image
")

(defn identify-dimensions [image-path]
  (let [result (shell/sh "identify" "-format" "%wx%h" image-path)]
    (when (zero? (:exit result))
      (let [[w h] (str/split (str/trim (:out result)) #"x")]
        {:width (parse-long w) :height (parse-long h)}))))

(defn auto-crop-content [input-path output-path]
  ;; Use ImageMagick's auto-trim to remove excess padding
  (shell/sh "magick" input-path "-fuzz" "10%" "-trim" "+repage" output-path))

(defn resize-to-match [input-path output-path target-dims]
  (let [{:keys [width height]} target-dims]
    (shell/sh "magick" input-path "-resize" (format "%dx%d!" width height) output-path)))

(defn compare-images [ref-path impl-path diff-path]
  (let [result (shell/sh "magick" "compare"
                         "-metric" "RMSE"
                         "-highlight-color" "red"
                         "-lowlight-color" "none"
                         ref-path impl-path diff-path
                         :err-to-out true)]
    {:diff-path diff-path
     :raw-output (:out result)
     :rmse (when-let [line (first (str/split-lines (:out result)))]
             (when-let [[_ rmse pct] (re-find #"([0-9.]+)\s+\(([0-9.]+)\)" line)]
               {:value (Double/parseDouble rmse)
                :percentage (* 100 (Double/parseDouble pct))}))}))

(defn -main [& args]
  (when (or (empty? args)
            (some #{"--help" "-h"} args))
    (println help-text)
    (System/exit 0))

  (let [ref-path (first args)
        impl-path (second args)
        output-dir (or (some #(when (= % "-o") (second (drop-while (partial not= %) args))) args)
                       "/tmp/visual-compare/")
        normalize? (some #{"--normalize"} args)
        threshold (or (some #(when (= % "--threshold")
                               (parse-double (second (drop-while (partial not= %) args))))
                           args)
                     10.0)]

    (fs/create-dirs output-dir)

    (println "╔════════════════════════════════════════════════════════╗")
    (println "║          Visual Compare - Programmatic Analysis        ║")
    (println "╚════════════════════════════════════════════════════════╝")
    (println)
    (println (format "Reference:      %s" ref-path))
    (println (format "Implementation: %s" impl-path))
    (println (format "Normalize:      %s" normalize?))
    (println (format "Threshold:      %.1f%%" threshold))
    (println)

    (let [ref-dims (identify-dimensions ref-path)
          impl-dims (identify-dimensions impl-path)]

      (println "Original dimensions:")
      (println (format "  Reference:      %dx%d" (:width ref-dims) (:height ref-dims)))
      (println (format "  Implementation: %dx%d" (:width impl-dims) (:height impl-dims)))
      (println)

      (let [[final-ref final-impl]
            (if normalize?
              (do
                (println "Normalizing...")
                (fs/create-dirs (str output-dir "normalized/"))
                (let [ref-trimmed (str output-dir "normalized/ref-trimmed.png")
                      impl-trimmed (str output-dir "normalized/impl-trimmed.png")
                      ref-final (str output-dir "normalized/ref-normalized.png")
                      impl-final (str output-dir "normalized/impl-normalized.png")]

                  ;; Auto-trim both
                  (auto-crop-content ref-path ref-trimmed)
                  (auto-crop-content impl-path impl-trimmed)

                  ;; Get smallest common dimensions
                  (let [ref-trim-dims (identify-dimensions ref-trimmed)
                        impl-trim-dims (identify-dimensions impl-trimmed)
                        target-width (min (:width ref-trim-dims) (:width impl-trim-dims))
                        target-height (min (:height ref-trim-dims) (:height impl-trim-dims))]

                    (println (format "  Trimmed to content, resizing to: %dx%d" target-width target-height))

                    ;; Resize both to same size
                    (resize-to-match ref-trimmed ref-final {:width target-width :height target-height})
                    (resize-to-match impl-trimmed impl-final {:width target-width :height target-height})

                    [ref-final impl-final])))
              [ref-path impl-path])]

        (println)
        (println "Comparing...")
        (let [diff-path (str output-dir "diff.png")
              metrics (compare-images final-ref final-impl diff-path)]

          (println)
          (println "Results:")
          (println (format "  RMSE:       %.2f" (get-in metrics [:rmse :value])))
          (println (format "  Difference: %.2f%%" (get-in metrics [:rmse :percentage])))
          (println (format "  Diff image: %s" diff-path))

          (spit (str output-dir "metrics.txt")
                (format "RMSE: %.2f\nPercentage: %.2f%%\nThreshold: %.2f%%\nPassed: %s\n"
                        (get-in metrics [:rmse :value])
                        (get-in metrics [:rmse :percentage])
                        threshold
                        (if (< (get-in metrics [:rmse :percentage]) threshold) "YES" "NO")))

          (println)
          (if (< (get-in metrics [:rmse :percentage]) threshold)
            (println (format "✓ PASSED (< %.1f%% threshold)" threshold))
            (println (format "✗ FAILED (>= %.1f%% threshold)" threshold)))))))

  (println))

(when (= *file* (System/getProperty "babashka.file"))
  (apply -main *command-line-args*))
