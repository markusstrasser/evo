#!/bin/bash
# Grok API wrapper using curl
# Usage: grok [-m model] [-p prompt] [< input.txt]

set -euo pipefail

# Defaults
MODEL="${GROK_MODEL:-grok-4}"
PROMPT=""
TEMPERATURE="0.7"

# Parse args
while [[ $# -gt 0 ]]; do
  case $1 in
    -m|--model)
      MODEL="$2"
      shift 2
      ;;
    -p|--prompt)
      PROMPT="$2"
      shift 2
      ;;
    -t|--temperature)
      TEMPERATURE="$2"
      shift 2
      ;;
    -h|--help)
      cat <<EOF
Grok API wrapper

Usage: grok [options]
       cat prompt.txt | grok
       grok -p "your question"

Options:
  -m, --model <model>         Model name (default: grok-4)
                              Options: grok-4, grok-4-latest, grok-code-fast-1
  -p, --prompt <prompt>       Prompt text (or read from stdin)
  -t, --temperature <float>   Temperature 0-1 (default: 0.7)
  -h, --help                  Show this help

Environment:
  GROK_API_KEY                xAI API key (required)
  GROK_MODEL                  Default model

Examples:
  grok -p "Explain Clojure macros"
  echo "What is a monad?" | grok -m grok-4-latest
  cat research-prompt.txt | grok > output.md
EOF
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      exit 1
      ;;
  esac
done

# Check API key
if [[ -z "${GROK_API_KEY:-}" ]]; then
  echo "Error: GROK_API_KEY not set" >&2
  exit 1
fi

# Read prompt from stdin if not provided
if [[ -z "$PROMPT" ]]; then
  if [[ -t 0 ]]; then
    echo "Error: No prompt provided. Use -p or pipe input." >&2
    exit 1
  fi
  PROMPT=$(cat)
fi

# Escape prompt for JSON
PROMPT_JSON=$(jq -n --arg p "$PROMPT" '$p')

# Call API
curl -s https://api.x.ai/v1/chat/completions \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer $GROK_API_KEY" \
  -d @- <<EOF | jq -r '.choices[0].message.content'
{
  "messages": [
    {
      "role": "user",
      "content": $PROMPT_JSON
    }
  ],
  "model": "$MODEL",
  "stream": false,
  "temperature": $TEMPERATURE
}
EOF
