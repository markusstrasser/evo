#!/bin/bash
# OpenAI API wrapper using curl
# Usage: openai [-m model] [-p prompt] [< input.txt]

set -euo pipefail

# Defaults
MODEL="${OPENAI_MODEL:-gpt-5-codex}"
PROMPT=""
TEMPERATURE="0.7"
MAX_TOKENS=""
REASONING_EFFORT="high"

# Parse args
while [[ $# -gt 0 ]]; do
  case $1 in
    -m|--model)
      MODEL="$2"
      shift 2
      ;;
    -p|--prompt)
      PROMPT="$2"
      shift 2
      ;;
    -t|--temperature)
      TEMPERATURE="$2"
      shift 2
      ;;
    --max-tokens)
      MAX_TOKENS="$2"
      shift 2
      ;;
    --reasoning-effort)
      REASONING_EFFORT="$2"
      shift 2
      ;;
    -h|--help)
      cat <<EOF
OpenAI API wrapper

Usage: openai [options]
       cat prompt.txt | openai
       openai -p "your question"

Options:
  -m, --model <model>         Model name (default: gpt-5-codex)
                              Options: gpt-4o, gpt-4o-mini, gpt-5, gpt-5-mini,
                                      gpt-5-nano, gpt-5-codex, o1, o1-mini, o3-mini
  -p, --prompt <prompt>       Prompt text (or read from stdin)
  -t, --temperature <float>   Temperature 0-2 (default: 0.7)
  --max-tokens <int>          Maximum tokens to generate
  --reasoning-effort <level>  Reasoning effort: low|medium|high (default: high)
                              Only for reasoning models (o1, o3, gpt-5)
  -h, --help                  Show this help

Environment:
  OPENAI_API_KEY              OpenAI API key (required)
  OPENAI_MODEL                Default model

Examples:
  openai -p "Explain Clojure macros"
  echo "What is a monad?" | openai -m gpt-4o
  cat research-prompt.txt | openai > output.md
  openai -m o1 -p "Solve this complex problem" --max-tokens 10000
EOF
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      exit 1
      ;;
  esac
done

# Check API key (try OPENAI_API_KEY first, fallback to .env)
if [[ -z "${OPENAI_API_KEY:-}" ]]; then
  if [[ -f .env ]]; then
    source .env
  fi
  if [[ -z "${OPENAI_API_KEY:-}" ]]; then
    echo "Error: OPENAI_API_KEY not set" >&2
    exit 1
  fi
fi

# Read prompt from stdin if not provided
if [[ -z "$PROMPT" ]]; then
  if [[ -t 0 ]]; then
    echo "Error: No prompt provided. Use -p or pipe input." >&2
    exit 1
  fi
  PROMPT=$(cat)
fi

# Escape prompt for JSON
PROMPT_JSON=$(jq -n --arg p "$PROMPT" '$p')

# Determine which API to use
# Responses API: gpt-5-codex, gpt-5*, o1*, o3*
# Chat Completions API: gpt-4o*, gpt-3.5*, etc.
USE_RESPONSES_API=false
if [[ "$MODEL" =~ ^(gpt-5|o1|o3) ]]; then
  USE_RESPONSES_API=true
fi

if [[ "$USE_RESPONSES_API" == "true" ]]; then
  # Responses API format (reasoning models don't support temperature)
  REQUEST_BODY=$(cat <<EOF
{
  "model": "$MODEL",
  "input": $PROMPT_JSON
  $(if [[ -n "$MAX_TOKENS" ]]; then echo ", \"max_output_tokens\": $MAX_TOKENS"; fi)
  $(if [[ -n "$REASONING_EFFORT" ]]; then echo ", \"reasoning\": { \"effort\": \"$REASONING_EFFORT\" }"; fi)
}
EOF
  )

  # Call Responses API
  echo "$REQUEST_BODY" | curl -s https://api.openai.com/v1/responses \
    -u :"$OPENAI_API_KEY" \
    -H "Content-Type: application/json" \
    -d @- | jq -r '.output[] | select(.type == "message") | .content[] | select(.type == "output_text") | .text'
else
  # Chat Completions API format
  REQUEST_BODY=$(cat <<EOF
{
  "messages": [
    {
      "role": "user",
      "content": $PROMPT_JSON
    }
  ],
  "model": "$MODEL",
  "stream": false,
  "temperature": $TEMPERATURE
  $(if [[ -n "$MAX_TOKENS" ]]; then echo ", \"max_tokens\": $MAX_TOKENS"; fi)
}
EOF
  )

  # Call Chat Completions API
  echo "$REQUEST_BODY" | curl -s https://api.openai.com/v1/chat/completions \
    -H "Content-Type: application/json" \
    -H "Authorization: Bearer $OPENAI_API_KEY" \
    -d @- | jq -r '.choices[0].message.content'
fi
