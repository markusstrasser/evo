#!/bin/bash
# Validate research output (proposals, rankings, results)
# Usage: scripts/validate-output [directory]
#        scripts/validate-output  # Auto-detect latest

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

OUTPUT_DIR="${1:-}"

# Auto-detect latest if not provided
if [[ -z "$OUTPUT_DIR" ]]; then
  OUTPUT_DIR=$(ls -td docs/research/proposals/* docs/research/results/* 2>/dev/null | head -1)
fi

if [[ -z "$OUTPUT_DIR" || ! -d "$OUTPUT_DIR" ]]; then
  echo -e "${RED}Error: No output directory found${NC}"
  echo "Usage: scripts/validate-output [directory]"
  exit 1
fi

echo -e "${GREEN}=== Validating: $OUTPUT_DIR ===${NC}"
echo ""

errors=0
warnings=0

# Check file count
echo "File count:"
md_count=$(find "$OUTPUT_DIR" -name "*.md" 2>/dev/null | wc -l)
echo "  Markdown files: $md_count"

if [[ $md_count -eq 0 ]]; then
  echo -e "${RED}✗ No markdown files found${NC}"
  errors=$((errors + 1))
fi

echo ""

# Check file sizes
echo "Checking file sizes (< 1KB usually indicates errors):"
small_files=$(find "$OUTPUT_DIR" -name "*.md" -size -1k 2>/dev/null)

if [[ -n "$small_files" ]]; then
  echo -e "${YELLOW}⚠ Small files found:${NC}"
  echo "$small_files" | while read -r file; do
    size=$(ls -lh "$file" | awk '{print $5}')
    echo "  $size - $file"
    warnings=$((warnings + 1))
  done
else
  echo -e "${GREEN}✓ All files > 1KB${NC}"
fi

echo ""

# Check for error messages
echo "Checking for error messages:"
error_files=$(grep -r -l -i "error\|failed\|exception\|not found\|not set" "$OUTPUT_DIR" --include="*.md" 2>/dev/null || true)

if [[ -n "$error_files" ]]; then
  echo -e "${YELLOW}⚠ Files with error keywords:${NC}"
  echo "$error_files" | while read -r file; do
    echo "  - $file"
    # Show first error line
    grep -i -m 1 "error\|failed\|exception\|not found\|not set" "$file" | sed 's/^/    > /'
  done
  warnings=$((warnings + 1))
else
  echo -e "${GREEN}✓ No error keywords found${NC}"
fi

echo ""

# Check for markdown structure
echo "Checking markdown structure:"
files_with_headers=$(find "$OUTPUT_DIR" -name "*.md" -exec grep -l "^#" {} \; 2>/dev/null | wc -l)

if [[ $md_count -gt 0 && $files_with_headers -eq $md_count ]]; then
  echo -e "${GREEN}✓ All files have markdown headers${NC}"
elif [[ $md_count -gt 0 ]]; then
  echo -e "${YELLOW}⚠ Some files missing headers ($files_with_headers/$md_count)${NC}"
  warnings=$((warnings + 1))
fi

echo ""

# Total size
echo "Total size:"
total_size=$(du -sh "$OUTPUT_DIR" 2>/dev/null | awk '{print $1}')
echo "  $total_size"

echo ""

# Summary
echo "=== Summary ==="
echo ""

if [[ $errors -eq 0 && $warnings -eq 0 ]]; then
  echo -e "${GREEN}✓ Validation passed - output looks good!${NC}"
  exit 0
elif [[ $errors -eq 0 ]]; then
  echo -e "${YELLOW}⚠ Validation passed with $warnings warning(s)${NC}"
  echo ""
  echo "Review warnings above - some files may contain errors"
  exit 0
else
  echo -e "${RED}✗ Validation failed with $errors error(s), $warnings warning(s)${NC}"
  echo ""
  echo "Fix errors before proceeding"
  exit 1
fi
