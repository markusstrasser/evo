#!/usr/bin/env bb
"""
Visual Validation Orchestrator - Multi-stage validation pipeline

Runs validation stages in order, stops on failure:
  Stage 1: Geometry (circularity, verticality, aspect ratio)
  Stage 2: Depth (height map comparison) [optional, requires ML models]
  Stage 3: Grid (pin array structure detection) [optional, requires ML models]
  Stage 4: Materials (texture/feature similarity) [optional, requires ML models]
  Stage 5: Structure (SSIM, RMSE, histogram correlation)
  Stage 6: AI Feedback (optional, aesthetic suggestions)

Usage:
  visual-validate <reference> <implementation> [options]

Options:
  --geometry-only         Stop after geometry validation
  --validate-depth        Enable depth validation (Depth Anything V2)
  --validate-grid         Enable grid structure validation (SAM 2)
  --validate-materials    Enable material/texture validation (DINOv2)
  --validate-all-ml       Enable all ML-based validations (depth + grid + materials)
  --skip-ai               Skip AI feedback
  --ai-prompt <text>      Custom prompt for AI analysis
  --output <dir>          Output directory (default: /tmp/visual-validation/)
  --normalize             Resize images to same dimensions before comparing
  -v, --verbose           Show detailed output
  -h, --help              Show this help

Examples:
  # Basic pipeline (geometry → structure)
  visual-validate ref.png impl.png

  # Full ML pipeline (geometry → depth → grid → materials → structure)
  visual-validate ref.png impl.png --validate-all-ml

  # Selective ML validations
  visual-validate ref.png impl.png --validate-depth --validate-materials

  # Geometry check only (for rapid iteration)
  visual-validate ref.png impl.png --geometry-only

Exit Codes:
  0 = All stages passed
  1 = Validation failed (see output for details)
  2 = Invalid arguments or missing dependencies
"""

(require '[clojure.string :as str]
         '[clojure.java.shell :as shell]
         '[babashka.fs :as fs])

(def help-text
  "Visual Validation Orchestrator - Multi-stage validation pipeline

Runs validation stages in order, stops on failure:
  Stage 1: Geometry (circularity, verticality, aspect ratio)
  Stage 2: Depth (height map comparison) [optional, requires ML models]
  Stage 3: Grid (pin array structure detection) [optional, requires ML models]
  Stage 4: Materials (texture/feature similarity) [optional, requires ML models]
  Stage 5: Structure (SSIM, RMSE, histogram correlation)
  Stage 6: AI Feedback (optional, aesthetic suggestions)

Usage:
  visual-validate <reference> <implementation> [options]

Options:
  --geometry-only         Stop after geometry validation
  --validate-depth        Enable depth validation (Depth Anything V2)
  --validate-grid         Enable grid structure validation (SAM 2)
  --validate-materials    Enable material/texture validation (DINOv2)
  --validate-all-ml       Enable all ML-based validations (depth + grid + materials)
  --skip-ai               Skip AI feedback
  --ai-prompt <text>      Custom prompt for AI analysis
  --output <dir>          Output directory (default: /tmp/visual-validation/)
  --normalize             Resize images to same dimensions before comparing
  -v, --verbose           Show detailed output
  -h, --help              Show this help

Examples:
  # Basic pipeline (geometry → structure)
  visual-validate ref.png impl.png

  # Full ML pipeline (geometry → depth → grid → materials → structure)
  visual-validate ref.png impl.png --validate-all-ml

  # Selective ML validations
  visual-validate ref.png impl.png --validate-depth --validate-materials

Exit Codes:
  0 = All stages passed
  1 = Validation failed (see output for details)
  2 = Invalid arguments or missing dependencies")

(defn parse-args [args]
  (loop [args args
         opts {:output-dir "/tmp/visual-validation/"
               :geometry-only false
               :skip-ai false
               :validate-depth false
               :validate-grid false
               :validate-materials false
               :ai-prompt nil
               :normalize false
               :verbose false}]
    (cond
      (empty? args)
      (if (and (:reference opts) (:implementation opts))
        opts
        (throw (ex-info "Missing required arguments" {:opts opts})))

      (#{"-h" "--help"} (first args))
      (do (println help-text) (System/exit 0))

      (= (first args) "--geometry-only")
      (recur (rest args) (assoc opts :geometry-only true))

      (= (first args) "--skip-ai")
      (recur (rest args) (assoc opts :skip-ai true))

      (= (first args) "--validate-depth")
      (recur (rest args) (assoc opts :validate-depth true))

      (= (first args) "--validate-grid")
      (recur (rest args) (assoc opts :validate-grid true))

      (= (first args) "--validate-materials")
      (recur (rest args) (assoc opts :validate-materials true))

      (= (first args) "--validate-all-ml")
      (recur (rest args) (assoc opts
                                :validate-depth true
                                :validate-grid true
                                :validate-materials true))

      (= (first args) "--normalize")
      (recur (rest args) (assoc opts :normalize true))

      (#{"-v" "--verbose"} (first args))
      (recur (rest args) (assoc opts :verbose true))

      (= (first args) "--output")
      (recur (drop 2 args) (assoc opts :output-dir (second args)))

      (= (first args) "--ai-prompt")
      (recur (drop 2 args) (assoc opts :ai-prompt (second args)))

      (nil? (:reference opts))
      (recur (rest args) (assoc opts :reference (first args)))

      (nil? (:implementation opts))
      (recur (rest args) (assoc opts :implementation (first args)))

      :else
      (throw (ex-info "Unknown argument" {:arg (first args)})))))

(defn check-dependencies []
  "Verify required tools are available"
  (let [python-check (shell/sh "which" "python3")
        opencv-check (shell/sh "python3" "-c" "import cv2; import skimage")
        magick-check (shell/sh "which" "magick")]
    (when-not (zero? (:exit python-check))
      (println "✗ Error: python3 not found")
      (System/exit 2))
    (when-not (zero? (:exit opencv-check))
      (println "✗ Error: Required Python packages not found")
      (println "  Install with: pip3 install opencv-python scikit-image numpy")
      (System/exit 2))
    (when-not (zero? (:exit magick-check))
      (println "✗ Error: ImageMagick not found")
      (println "  Install with: brew install imagemagick")
      (System/exit 2))))

(defn run-stage [name command verbose?]
  "Run a validation stage, return exit code"
  (println)
  (println (format "═══════════════════════════════════════════════════════"))
  (println (format "Stage: %s" name))
  (println (format "═══════════════════════════════════════════════════════"))
  (println)

  (let [result (apply shell/sh (concat command (when verbose? ["-v"])))]
    (print (:out result))
    (when-not (str/blank? (:err result))
      (print (:err result)))
    (:exit result)))

(defn run-ai-feedback [ref impl output-dir custom-prompt verbose?]
  "Run AI analysis using Gemini (optional stage 3)"
  (println)
  (println "═══════════════════════════════════════════════════════")
  (println "Stage 3: AI Aesthetic Feedback (Optional)")
  (println "═══════════════════════════════════════════════════════")
  (println)

  ;; Create side-by-side comparison
  (let [comparison-path (str output-dir "comparison.png")
        _ (shell/sh "magick" ref impl "+append" comparison-path)
        prompt (or custom-prompt
                   "LEFT=reference (target), RIGHT=implementation (current).
Geometry and structure are validated. Focus on:
- Material properties (shininess, roughness, reflectivity)
- Lighting quality (direction, intensity, shadows)
- Color/tone adjustments
- Perceptual polish

What specific numeric parameter changes would improve the match?")]

    (println "Creating side-by-side comparison...")
    (println (format "Saved: %s" comparison-path))
    (println)
    (println "Running Gemini analysis...")
    (println)

    ;; Run gemini CLI (assumes it's available)
    (let [result (shell/sh "gemini" "image" "analyze" comparison-path "-p" prompt)]
      (if (zero? (:exit result))
        (do
          (println (:out result))
          (spit (str output-dir "ai-feedback.txt") (:out result))
          (println)
          (println (format "AI feedback saved: %s" (str output-dir "ai-feedback.txt")))
          0)
        (do
          (println "⚠ AI analysis failed (gemini not available or error)")
          (println "  Skipping AI feedback - quantitative validation passed")
          0)))))

(defn -main [& args]
  (let [{:keys [reference implementation output-dir geometry-only skip-ai
                validate-depth validate-grid validate-materials
                ai-prompt normalize verbose]} (parse-args args)]

    (println "╔═══════════════════════════════════════════════════════╗")
    (println "║       Visual Validation - Multi-Stage Pipeline       ║")
    (println "╚═══════════════════════════════════════════════════════╝")
    (println)
    (println (format "Reference:      %s" reference))
    (println (format "Implementation: %s" implementation))
    (println (format "Output:         %s" output-dir))

    ;; Build pipeline description
    (let [ml-stages (cond-> []
                      validate-depth (conj "Depth")
                      validate-grid (conj "Grid")
                      validate-materials (conj "Materials"))
          pipeline-desc (cond
                          geometry-only "Geometry only"
                          (seq ml-stages) (str "Geometry + " (str/join " + " ml-stages) " + Structure")
                          skip-ai "Geometry + Structure"
                          :else "Geometry + Structure + AI")]
      (println (format "Pipeline:       %s" pipeline-desc)))
    (println)

    ;; Check dependencies
    (when verbose
      (println "Checking dependencies..."))
    (check-dependencies)

    (fs/create-dirs output-dir)

    ;; Stage 1: Geometry (always)
    (let [geo-output (str output-dir "geometry/")
          stage-num (atom 1)
          total-stages (+ 2  ; geometry + structure
                          (if validate-depth 1 0)
                          (if validate-grid 1 0)
                          (if validate-materials 1 0)
                          (if (and (not skip-ai) (not geometry-only)) 1 0))]

      (let [stage1-exit (run-stage
                         (format "%d/%d - Geometry Validation" @stage-num total-stages)
                         ["scripts/visual-validate-geometry"
                          reference implementation
                          "--output" geo-output]
                         verbose)]

        (when-not (zero? stage1-exit)
          (println)
          (println "❌ VALIDATION FAILED at Stage 1 (Geometry)")
          (println)
          (println "Fix geometric issues before proceeding.")
          (System/exit 1))

        ;; Stop if geometry-only
        (when geometry-only
          (println)
          (println "✓ Geometry validation passed (geometry-only mode)")
          (System/exit 0))

        (swap! stage-num inc))

      ;; Stage 2 (optional): Depth
      (when validate-depth
        (let [depth-output (str output-dir "depth/")
              depth-exit (run-stage
                          (format "%d/%d - Depth Validation (ML)" @stage-num total-stages)
                          ["scripts/visual-validate-depth"
                           implementation reference
                           "--output-dir" depth-output]
                          verbose)]

          (when-not (zero? depth-exit)
            (println)
            (println "❌ VALIDATION FAILED at Depth Validation")
            (println)
            (println "Fix depth/height issues before proceeding.")
            (System/exit 1))

          (swap! stage-num inc)))

      ;; Stage 3 (optional): Grid
      (when validate-grid
        (let [grid-output (str output-dir "grid/")
              grid-exit (run-stage
                         (format "%d/%d - Grid Validation (ML)" @stage-num total-stages)
                         ["scripts/visual-validate-grid"
                          implementation reference
                          "--output-dir" grid-output]
                         verbose)]

          (when-not (zero? grid-exit)
            (println)
            (println "❌ VALIDATION FAILED at Grid Validation")
            (println)
            (println "Fix grid structure issues before proceeding.")
            (System/exit 1))

          (swap! stage-num inc)))

      ;; Stage 4 (optional): Materials
      (when validate-materials
        (let [material-output (str output-dir "materials/")
              material-exit (run-stage
                             (format "%d/%d - Material Validation (ML)" @stage-num total-stages)
                             ["scripts/visual-validate-materials"
                              implementation reference
                              "--output-dir" material-output]
                             verbose)]

          (when-not (zero? material-exit)
            (println)
            (println "❌ VALIDATION FAILED at Material Validation")
            (println)
            (println "Fix material/texture issues before proceeding.")
            (System/exit 1))

          (swap! stage-num inc)))

      ;; Stage 5: Structure (always unless geometry-only)
      (let [struct-output (str output-dir "structure/")
            normalize-flag (if normalize ["--normalize"] [])
            struct-exit (run-stage
                         (format "%d/%d - Structural Validation" @stage-num total-stages)
                         (concat ["scripts/visual-validate-structure"
                                  implementation reference
                                  "--output" struct-output]
                                 normalize-flag)
                         verbose)]

        (when-not (zero? struct-exit)
          (println)
          (println "❌ VALIDATION FAILED at Structural Validation")
          (println)
          (println "Fix structural issues before aesthetic refinement.")
          (System/exit 1))

        (swap! stage-num inc))

      ;; All quantitative validation passed
      (println)
      (println "✅ QUANTITATIVE VALIDATION PASSED")
      (println)
      (println "All validation stages passed.")

      ;; Stage 6 (optional): AI Feedback
      (when-not skip-ai
        (run-ai-feedback reference implementation output-dir ai-prompt verbose))

      (println)
      (println "════════════════════════════════════════════════════════")
      (println)
      (println "✓ ALL VALIDATION STAGES COMPLETED")
      (println)
      (println (format "Results saved to: %s" output-dir))
      (System/exit 0))))

(when (= *file* (System/getProperty "babashka.file"))
  (apply -main *command-line-args*))
