#!/usr/bin/env bash
# Research best-of repos for architectural patterns
# Runs 15 parallel queries: 5 repos × 3 models
#
# Usage: scripts/best-repos-research [question]

set -euo pipefail

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;36m'
NC='\033[0m'

# Paths
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
BEST_DIR="$HOME/Projects/best"
OVERVIEW_FILE="$PROJECT_ROOT/docs/2025-09-30-19-34-src-overview.md"
CACHE_DIR="$PROJECT_ROOT/.repomix-cache"

# Load environment variables
if [[ -f "$PROJECT_ROOT/.env" ]]; then
  set -a
  source "$PROJECT_ROOT/.env"
  set +a
fi

# Output directory
OUTPUT_DIR="$PROJECT_ROOT/research/results/$(date +%Y-%m-%d-%H-%M)"

# Research question (default if not provided)
RESEARCH_QUESTION="${1:-How does this project implement its core data structures and operations? Focus on: 1) Core abstractions 2) Extensibility patterns 3) State management 4) Derived/computed values}"

echo -e "${GREEN}=== Best-of Repos Research ===${NC}"
echo ""
echo -e "${BLUE}Question:${NC}"
echo "  $RESEARCH_QUESTION"
echo ""

# Target repositories with scoped paths
# Format: "name:path:include_pattern"
declare -A repos=(
  ["datascript"]="$BEST_DIR/datascript:src/datascript:*.cljc,*.clj"
  ["reitit"]="$BEST_DIR/reitit:modules/reitit-core/src:*.cljc,*.clj"
  ["re-frame"]="$BEST_DIR/re-frame:src/re_frame:*.cljc,*.clj"
  ["meander"]="$BEST_DIR/meander:src/meander:*.cljc,*.clj"
  ["specter"]="$BEST_DIR/specter:src/clj/com/rpl/specter:*.cljc,*.clj"
)

# Models
models=("gemini" "codex" "grok")

# Create output and cache directories
mkdir -p "$OUTPUT_DIR"
mkdir -p "$CACHE_DIR"

echo -e "${BLUE}Repositories:${NC}"
for repo_name in "${!repos[@]}"; do
  echo "  - $repo_name"
done
echo ""

echo -e "${BLUE}Models:${NC}"
for model in "${models[@]}"; do
  echo "  - $model"
done
echo ""

# Read overview
if [[ ! -f "$OVERVIEW_FILE" ]]; then
  echo -e "${RED}Error: Overview file not found: $OVERVIEW_FILE${NC}"
  exit 1
fi

overview_content=$(cat "$OVERVIEW_FILE")

# Track PIDs
declare -a pids=()
query_count=0

echo -e "${GREEN}Starting $((${#repos[@]} * ${#models[@]})) parallel queries...${NC}"
echo ""

# For each repository
for repo_name in "${!repos[@]}"; do
  repo_info="${repos[$repo_name]}"
  IFS=: read -r repo_path repo_subdir include_pattern <<< "$repo_info"

  if [[ ! -d "$repo_path" ]]; then
    echo -e "${YELLOW}Warning: Repository not found: $repo_path${NC}"
    echo -e "${YELLOW}Skipping $repo_name${NC}"
    echo ""
    continue
  fi

  echo -e "${BLUE}Processing: $repo_name${NC}"
  echo "  Path: $repo_path/$repo_subdir"
  echo ""

  # Check cache first
  cache_key=$(echo "$repo_path/$repo_subdir:$include_pattern" | md5)
  cache_file="$CACHE_DIR/${repo_name}-${cache_key}.txt"

  if [[ -f "$cache_file" ]]; then
    echo "  Using cached repomix..."
    repo_context=$(cat "$cache_file")
  else
    # Generate repomix for this repo (scoped)
    echo "  Generating repomix..."
    repo_context=$(repomix "$repo_path/$repo_subdir" \
      --include "$include_pattern" \
      --copy \
      --output /dev/null 2>&1 && pbpaste || echo "Error generating repomix")

    # Cache the result
    echo "$repo_context" > "$cache_file"
    echo "  Cached to: .repomix-cache/$(basename "$cache_file")"
  fi

  # Build prompt
  full_prompt=$(cat <<EOF
<evo-context>
PROJECT OVERVIEW (EVO - our project):

$overview_content
</evo-context>

<target-repository>
TARGET FOR ANALYSIS ($repo_name):

$repo_context
</target-repository>

<research-question>
$RESEARCH_QUESTION

Analyze $repo_name's approach and extract patterns that could inspire EVO's architecture.
Be specific with code examples. Focus on simplicity, readability, and elegance.
</research-question>
EOF
)

  # Query each model
  for model in "${models[@]}"; do
    ((query_count++))
    output_file="$OUTPUT_DIR/${repo_name}-${model}.md"

    case "$model" in
      gemini)
        (
          echo "$full_prompt" | \
            gemini --allowed-mcp-server-names "" -y > "$output_file" 2>&1 && \
            echo "$(date +%H:%M:%S) ✓ ${repo_name}-${model}" || \
            echo "$(date +%H:%M:%S) ✗ ${repo_name}-${model} FAILED"
        ) &
        pids+=($!)
        ;;
      codex)
        (
          echo "$full_prompt" | \
            codex exec -m gpt-5-codex -c model_reasoning_effort="high" - > "$output_file" 2>&1 && \
            echo "$(date +%H:%M:%S) ✓ ${repo_name}-${model}" || \
            echo "$(date +%H:%M:%S) ✗ ${repo_name}-${model} FAILED"
        ) &
        pids+=($!)
        ;;
      grok)
        (
          echo "$full_prompt" | \
            "$SCRIPT_DIR/grok" -m grok-4-latest > "$output_file" 2>&1 && \
            echo "$(date +%H:%M:%S) ✓ ${repo_name}-${model}" || \
            echo "$(date +%H:%M:%S) ✗ ${repo_name}-${model} FAILED"
        ) &
        pids+=($!)
        ;;
    esac
  done

  echo ""
done

echo -e "${BLUE}Waiting for all $query_count queries to complete...${NC}"
echo -e "${YELLOW}Note: Codex queries may take 2-5 minutes each${NC}"
echo ""

# Wait with progress tracking
total_pids=${#pids[@]}
while true; do
  completed=0
  for pid in "${pids[@]}"; do
    if ! kill -0 $pid 2>/dev/null; then
      ((completed++))
    fi
  done

  if [[ $completed -eq $total_pids ]]; then
    break
  fi

  echo -ne "\r  Progress: $completed/$total_pids completed...  "
  sleep 3
done

echo ""
echo -e "${GREEN}✓ All queries completed${NC}"
echo ""

# Validate output
echo -e "${BLUE}Validating results...${NC}"
"$SCRIPT_DIR/validate-output" "$OUTPUT_DIR"

echo ""
echo -e "${GREEN}=== Results ===${NC}"
echo ""
echo "Output directory: $OUTPUT_DIR"
echo ""
echo "Files:"
ls -1 "$OUTPUT_DIR"/*.md 2>/dev/null | while read -r file; do
  size=$(ls -lh "$file" | awk '{print $5}')
  echo "  $size  $(basename "$file")"
done

echo ""
echo -e "${GREEN}Done!${NC}"
