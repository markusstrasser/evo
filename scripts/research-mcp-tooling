#!/bin/bash
# Research MCP tooling design from recent papers

set -euo pipefail

RESEARCH_DIR="research/papers-mcp-tooling"
mkdir -p "$RESEARCH_DIR"

echo "MCP Tooling Research - Paper Search & Synthesis"
echo "================================================"
echo ""

# Phase 1: Paper Search (parallel)
echo "Phase 1: Launching 8 paper search agents..."
echo ""

declare -A queries=(
  ["1-ai-native-workflows"]="LLM-assisted software development workflow 2024"
  ["2-multi-agent-systems"]="Multi-agent systems software engineering 2024"
  ["3-decision-support"]="AI architectural decision records generation"
  ["4-spec-refinement"]="Incremental specification refinement LLM"
  ["5-provenance"]="Provenance tracking machine learning systems"
  ["6-knowledge-mgmt"]="Knowledge graphs software engineering LLM"
  ["7-tool-composition"]="Composable AI tools software development"
  ["8-quality-gates"]="Validation AI-generated code quality gates"
)

for area in "${!queries[@]}"; do
  search_query="${queries[$area]}"
  mkdir -p "$RESEARCH_DIR/$area"

  echo "  Launching: $area"

  # Launch agent in background
  (
    cat > "$RESEARCH_DIR/$area/prompt.md" << EOF
Search for recent papers (2023-2025) on: $search_query

Focus on:
- Conference papers (ICSE, FSE, ASE, NeurIPS, ICLR, PLDI)
- arXiv preprints
- Papers with code/data availability

For each paper, extract:
1. Title, authors, venue, year
2. Core contribution (1 sentence)
3. Key findings (3-5 bullet points)
4. Architecture/approach (if applicable)
5. Limitations and future work
6. Relevance to MCP-based review tooling

Prioritize papers that discuss:
- AI-native development workflows
- Human-AI collaboration patterns
- Tool composition and extensibility
- Provenance tracking
- Quality gates and validation

Format as markdown.
EOF

    # Use Exa MCP for academic search via codex
    cat "$RESEARCH_DIR/$area/prompt.md" | \
      codex exec -m gpt-5-codex -c model_reasoning_effort="high" --full-auto - \
      > "$RESEARCH_DIR/$area/papers.md" 2>&1

    echo "✓ Complete: $area" >&2
  ) &
done

echo ""
echo "  Waiting for all searches to complete..."
wait
echo ""
echo "✓ Phase 1 complete: 8 paper summaries generated"
echo ""

# Phase 2: Synthesis
echo "Phase 2: Synthesizing findings..."
echo ""

cat > /tmp/synthesis-prompt.md << 'EOF'
# Synthesis Task

Analyze all paper summaries below and extract:

## 1. Common Architectural Patterns
- What architectures appear across multiple papers?
- What primitives are used (graphs, URIs, prompts, agents)?
- What composition patterns work well?

## 2. Successful Approaches
- Which approaches have empirical validation?
- What quality metrics are used?
- How is human-in-the-loop handled?

## 3. Known Failure Modes
- What doesn't work?
- What are common pitfalls?
- What tradeoffs are unavoidable?

## 4. Gaps in Research
- What's missing?
- What's specific to our use case?
  - Solo developer (not team)
  - REPL-driven development
  - Clojure ecosystem
  - Simplicity over performance

## 5. Recommendations
- Top 3 patterns to adopt
- Top 3 anti-patterns to avoid
- Concrete suggestions for MCP architecture

---

# Paper Summaries

EOF

# Collect all paper summaries
for area in "${!queries[@]}"; do
  echo "" >> /tmp/synthesis-prompt.md
  echo "## $area" >> /tmp/synthesis-prompt.md
  echo "" >> /tmp/synthesis-prompt.md
  cat "$RESEARCH_DIR/$area/papers.md" >> /tmp/synthesis-prompt.md
done

# Run synthesis agent
cat /tmp/synthesis-prompt.md | \
  codex exec -m gpt-5-codex -c model_reasoning_effort="high" --full-auto - \
  > "$RESEARCH_DIR/SYNTHESIS.md"

echo "✓ Phase 2 complete: Synthesis generated"
echo ""

# Phase 3: Design
echo "Phase 3: Generating concrete architecture..."
echo ""

cat > /tmp/design-prompt.md << 'EOF'
# Design Task

Given:
1. Paper synthesis (patterns, approaches, gaps)
2. Existing MCP proposals (Gemini resource-centric, Codex coordinator)
3. Project constraints (solo dev, REPL-driven, simplicity)

Task: Design concrete MCP architecture for review process tooling.

## Requirements

**Must Address**:
- Ideas → Proposals → Specs → ADRs workflow
- Provenance tracking (which proposal → which ADR?)
- Composable stages (swap independently)
- Integration with existing `bb` scripts
- Quality gates (validation, testing)

**Design Decisions**:
1. Single server vs composition?
2. Resource URI scheme?
3. Tool signatures (with types)?
4. Context passing between stages?
5. Evaluation integration (evo-eval MCP)?

**Deliverables**:
1. Architecture diagram (ASCII or structured text)
2. Server composition structure
3. Tool signatures (Python FastMCP)
4. Resource URI scheme with examples
5. Data flow example (Idea → ADR)
6. Implementation roadmap (4 phases)

---

# Context

EOF

# Add existing proposals
echo "## Existing MCP Proposals" >> /tmp/design-prompt.md
echo "" >> /tmp/design-prompt.md
echo "### Gemini (Resource-Centric)" >> /tmp/design-prompt.md
head -100 research/mcp-tooling-proposals/gemini-2025-10-13.md >> /tmp/design-prompt.md
echo "" >> /tmp/design-prompt.md
echo "### Codex (Coordinator)" >> /tmp/design-prompt.md
tail -n +500 research/mcp-tooling-proposals/codex-2025-10-13.md | head -100 >> /tmp/design-prompt.md

# Add synthesis
echo "" >> /tmp/design-prompt.md
echo "## Paper Synthesis" >> /tmp/design-prompt.md
cat "$RESEARCH_DIR/SYNTHESIS.md" >> /tmp/design-prompt.md

# Run design agent
cat /tmp/design-prompt.md | \
  codex exec -m gpt-5-codex -c model_reasoning_effort="high" --full-auto - \
  > "$RESEARCH_DIR/DESIGN.md"

echo "✓ Phase 3 complete: Architecture designed"
echo ""

# Summary
echo ""
echo "=== RESEARCH COMPLETE ==="
echo ""
echo "Outputs:"
echo "  - $RESEARCH_DIR/RESEARCH_OUTLINE.md (this plan)"
echo "  - $RESEARCH_DIR/1-*  through  $RESEARCH_DIR/8-* (paper summaries)"
echo "  - $RESEARCH_DIR/SYNTHESIS.md (cross-cutting patterns)"
echo "  - $RESEARCH_DIR/DESIGN.md (recommended architecture)"
echo ""
echo "Next steps:"
echo "  1. Review DESIGN.md"
echo "  2. Compare designs with evo-eval MCP:"
echo "     - Use compare_multiple tool"
echo "     - Include: Gemini, Codex, paper-synthesis designs"
echo "  3. Prototype Phase 1 (minimal viable MCP)"
echo ""
echo "Total runtime: ~2-3 hours"
