#!/bin/bash
# Gemini Media API wrapper for Veo 3 (video) and Imagen 3 (image) generation
# Usage: gemini-media video generate -p "prompt"
#        gemini-media image generate -p "prompt"
#        gemini-media video analyze <file> -p "question"

set -euo pipefail

# Auto-source .env if it exists (relative to script location or cwd)
if [[ -f "${BASH_SOURCE[0]%/*}/../.env" ]]; then
  set -a
  source "${BASH_SOURCE[0]%/*}/../.env"
  set +a
elif [[ -f .env ]]; then
  set -a
  source .env
  set +a
fi

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# API configuration
BASE_URL="https://generativelanguage.googleapis.com/v1beta"
UPLOAD_URL="https://generativelanguage.googleapis.com/upload/v1beta"

# Defaults
MODEL_VIDEO="veo-3.0-generate-001"
MODEL_IMAGE="imagen-4.0-generate-001"
MODEL_ANALYZE="gemini-2.5-flash"
ASPECT_RATIO="16:9"
RESOLUTION="720p"
NUM_IMAGES=4
OUTPUT_DIR="./gemini-output"
POLL_INTERVAL=10

# Helper functions
log_info() {
  echo -e "${BLUE}ℹ${NC} $1" >&2
}

log_success() {
  echo -e "${GREEN}✓${NC} $1" >&2
}

log_error() {
  echo -e "${RED}✗${NC} $1" >&2
}

log_warning() {
  echo -e "${YELLOW}⚠${NC} $1" >&2
}

check_api_key() {
  if [[ -z "${GEMINI_API_KEY:-}" ]]; then
    log_error "GEMINI_API_KEY not set"
    log_info "Get your API key at: https://aistudio.google.com/apikey"
    exit 1
  fi
}

show_help() {
  cat <<EOF
Gemini Media API - Video and Image Generation Tool

Usage:
  gemini-media video generate -p <prompt> [options]
  gemini-media video analyze <file> -p <question> [options]
  gemini-media image generate -p <prompt> [options]

Commands:
  video generate    Generate video using Veo 3
  video analyze     Analyze video and answer questions
  image generate    Generate images using Imagen 3

Video Generation Options:
  -p, --prompt <text>           Video description (required)
  -n, --negative <text>         Negative prompt
  -a, --aspect-ratio <ratio>    Aspect ratio: 16:9 or 9:16 (default: 16:9)
  -r, --resolution <res>        Resolution: 720p or 1080p (default: 720p)
  -o, --output <file>           Output file path (default: ./gemini-output/video-*.mp4)

Video Analysis Options:
  <file>                        Video file to analyze
  -p, --prompt <question>       Question about the video (required)
  -o, --output <file>           Output file for response (optional)

Image Generation Options:
  -p, --prompt <text>           Image description (required)
  -n, --num-images <count>      Number of images: 1-4 (default: 4)
  -o, --output <dir>            Output directory (default: ./gemini-output)

Global Options:
  -h, --help                    Show this help

Environment Variables:
  GEMINI_API_KEY                API key (required)

Examples:
  # Generate a video
  gemini-media video generate -p "A cat playing piano" -r 1080p

  # Analyze a video
  gemini-media video analyze my-video.mp4 -p "What is happening in this video?"

  # Generate images
  gemini-media image generate -p "Robot holding a red skateboard" -n 4

  # Generate with custom output
  gemini-media video generate -p "Sunset over ocean" -o sunset.mp4
EOF
}

# Upload file to Gemini File API
upload_file() {
  local file_path="$1"
  local mime_type="$2"

  log_info "Uploading file: $(basename "$file_path")"

  # Get file size
  local file_size=$(wc -c < "$file_path" | tr -d ' ')

  # Step 1: Start resumable upload and get upload URL
  local start_response=$(curl -s -X POST \
    "${UPLOAD_URL}/files" \
    -H "x-goog-api-key: ${GEMINI_API_KEY}" \
    -H "X-Goog-Upload-Protocol: resumable" \
    -H "X-Goog-Upload-Command: start" \
    -H "X-Goog-Upload-Header-Content-Length: ${file_size}" \
    -H "X-Goog-Upload-Header-Content-Type: ${mime_type}" \
    -H "Content-Type: application/json" \
    -d "{\"file\": {\"display_name\": \"$(basename "$file_path")\"}}")

  # Extract upload URL from headers
  local upload_url=$(echo "$start_response" | grep -i "x-goog-upload-url:" | cut -d' ' -f2 | tr -d '\r')

  # If not in headers, try to get from Location header
  if [[ -z "$upload_url" ]]; then
    # Try a different approach - use curl -D to get headers
    local temp_headers=$(mktemp)
    curl -s -D "$temp_headers" -X POST \
      "${UPLOAD_URL}/files" \
      -H "x-goog-api-key: ${GEMINI_API_KEY}" \
      -H "X-Goog-Upload-Protocol: resumable" \
      -H "X-Goog-Upload-Command: start" \
      -H "X-Goog-Upload-Header-Content-Length: ${file_size}" \
      -H "X-Goog-Upload-Header-Content-Type: ${mime_type}" \
      -H "Content-Type: application/json" \
      -d "{\"file\": {\"display_name\": \"$(basename "$file_path")\"}}" > /dev/null

    upload_url=$(grep -i "x-goog-upload-url:" "$temp_headers" | cut -d' ' -f2 | tr -d '\r')
    rm "$temp_headers"
  fi

  if [[ -z "$upload_url" ]]; then
    log_error "Failed to get upload URL"
    echo "$start_response" >&2
    return 1
  fi

  # Step 2: Upload the file content
  local upload_response=$(curl -s -X POST \
    "$upload_url" \
    -H "Content-Length: ${file_size}" \
    -H "X-Goog-Upload-Offset: 0" \
    -H "X-Goog-Upload-Command: upload, finalize" \
    --data-binary "@${file_path}")

  # Extract file URI
  local file_uri=$(echo "$upload_response" | jq -r '.file.uri // empty')

  if [[ -z "$file_uri" ]]; then
    log_error "Upload failed: $(echo "$upload_response" | jq -r '.error.message // "Unknown error"')"
    echo "$upload_response" >&2
    return 1
  fi

  log_success "Uploaded: $file_uri"

  # Step 3: Poll until file is ACTIVE
  log_info "Waiting for file to become ACTIVE..."
  local file_name=$(echo "$file_uri" | sed 's|https://generativelanguage.googleapis.com/v1beta/||')

  while true; do
    local status_response=$(curl -s \
      "${BASE_URL}/${file_name}" \
      -H "x-goog-api-key: ${GEMINI_API_KEY}")

    local state=$(echo "$status_response" | jq -r '.state // empty')

    if [[ "$state" == "ACTIVE" ]]; then
      log_success "File is ready"
      break
    elif [[ "$state" == "FAILED" ]]; then
      log_error "File processing failed"
      echo "$status_response" >&2
      return 1
    fi

    echo -n "." >&2
    sleep 5
  done

  echo "$file_uri"
}

# Poll long-running operation
poll_operation() {
  local operation_name="$1"

  log_info "Polling operation status (this may take 1-2 minutes)..."

  while true; do
    local response=$(curl -s \
      "${BASE_URL}/${operation_name}" \
      -H "x-goog-api-key: ${GEMINI_API_KEY}")

    local done=$(echo "$response" | jq -r '.done // false')

    if [[ "$done" == "true" ]]; then
      local error=$(echo "$response" | jq -r '.error // empty')
      if [[ -n "$error" ]]; then
        log_error "Operation failed: $(echo "$response" | jq -r '.error.message')"
        return 1
      fi

      log_success "Operation complete"
      echo "$response"
      return 0
    fi

    echo -n "." >&2
    sleep $POLL_INTERVAL
  done
}

# Download file from URI
download_file() {
  local uri="$1"
  local output_path="$2"

  log_info "Downloading to: $output_path"

  # Download file (follow redirects with -L)
  # URI is already a full download URL with alt=media
  curl -s -L "${uri}" \
    -H "x-goog-api-key: ${GEMINI_API_KEY}" \
    -o "$output_path"

  if [[ -f "$output_path" && -s "$output_path" ]]; then
    local file_size=$(du -h "$output_path" | cut -f1)
    log_success "Downloaded: $output_path ($file_size)"
  else
    log_error "Download failed or file is empty"
    return 1
  fi
}

# Generate video using Veo 3
generate_video() {
  local prompt="$1"
  local negative_prompt="${2:-}"
  local aspect_ratio="${3:-16:9}"
  local resolution="${4:-720p}"
  local output_file="${5:-}"

  check_api_key

  # Create output directory
  mkdir -p "$OUTPUT_DIR"

  # Generate default output filename if not provided
  if [[ -z "$output_file" ]]; then
    local timestamp=$(date +%Y%m%d-%H%M%S)
    output_file="${OUTPUT_DIR}/video-${timestamp}.mp4"
  fi

  log_info "Generating video with Veo 3..."
  log_info "Prompt: $prompt"
  log_info "Aspect ratio: $aspect_ratio, Resolution: $resolution"

  # Build request (parameters go in separate object)
  if [[ -n "$negative_prompt" ]]; then
    local request_body=$(jq -n \
      --arg prompt "$prompt" \
      --arg negative "$negative_prompt" \
      --arg aspect "$aspect_ratio" \
      --arg res "$resolution" \
      '{
        instances: [{
          prompt: $prompt
        }],
        parameters: {
          aspectRatio: $aspect,
          resolution: $res,
          negativePrompt: $negative
        }
      }')
  else
    local request_body=$(jq -n \
      --arg prompt "$prompt" \
      --arg aspect "$aspect_ratio" \
      --arg res "$resolution" \
      '{
        instances: [{
          prompt: $prompt
        }],
        parameters: {
          aspectRatio: $aspect,
          resolution: $res
        }
      }')
  fi

  # Submit generation request
  local response=$(curl -s -X POST \
    "${BASE_URL}/models/${MODEL_VIDEO}:predictLongRunning" \
    -H "x-goog-api-key: ${GEMINI_API_KEY}" \
    -H "Content-Type: application/json" \
    -d "$request_body")

  # Check for errors
  local error=$(echo "$response" | jq -r '.error // empty')
  if [[ -n "$error" ]]; then
    log_error "Generation failed: $(echo "$response" | jq -r '.error.message')"
    return 1
  fi

  # Extract operation name
  local operation_name=$(echo "$response" | jq -r '.name')

  if [[ -z "$operation_name" || "$operation_name" == "null" ]]; then
    log_error "No operation name returned"
    echo "$response" | jq . >&2
    return 1
  fi

  log_info "Operation: $operation_name"

  # Poll for completion
  local result=$(poll_operation "$operation_name")

  # Extract video URI (try multiple possible paths)
  local video_uri=$(echo "$result" | jq -r '
    .response.generateVideoResponse.generatedSamples[0].video.uri //
    .response.predictions[0].videoUri //
    .response.predictions[0].uri //
    empty
  ')

  if [[ -z "$video_uri" ]]; then
    log_error "No video URI in response"
    echo "$result" | jq . >&2
    return 1
  fi

  log_success "Video generated: $video_uri"

  # Download video
  download_file "$video_uri" "$output_file"

  echo "$output_file"
}

# Analyze video
analyze_video() {
  local video_file="$1"
  local question="$2"
  local output_file="${3:-}"

  check_api_key

  if [[ ! -f "$video_file" ]]; then
    log_error "Video file not found: $video_file"
    return 1
  fi

  log_info "Analyzing video: $(basename "$video_file")"

  # Detect MIME type
  local mime_type="video/mp4"
  case "${video_file##*.}" in
    mp4) mime_type="video/mp4" ;;
    mpeg|mpg) mime_type="video/mpeg" ;;
    mov) mime_type="video/mov" ;;
    avi) mime_type="video/x-msvideo" ;;
    webm) mime_type="video/webm" ;;
    *) log_warning "Unknown video format, assuming mp4" ;;
  esac

  # Upload video
  local file_uri=$(upload_file "$video_file" "$mime_type")

  if [[ -z "$file_uri" ]]; then
    return 1
  fi

  log_info "Analyzing with question: $question"

  # Build request
  local request_body=$(jq -n \
    --arg uri "$file_uri" \
    --arg q "$question" \
    '{
      contents: [{
        parts: [
          {fileData: {fileUri: $uri, mimeType: "video/mp4"}},
          {text: $q}
        ]
      }]
    }')

  # Send analysis request
  local response=$(curl -s -X POST \
    "${BASE_URL}/models/${MODEL_ANALYZE}:generateContent" \
    -H "x-goog-api-key: ${GEMINI_API_KEY}" \
    -H "Content-Type: application/json" \
    -d "$request_body")

  # Extract answer
  local answer=$(echo "$response" | jq -r '.candidates[0].content.parts[0].text // empty')

  if [[ -z "$answer" ]]; then
    log_error "No answer received"
    echo "$response" | jq . >&2
    return 1
  fi

  log_success "Analysis complete"

  # Output result
  if [[ -n "$output_file" ]]; then
    echo "$answer" > "$output_file"
    log_success "Saved to: $output_file"
  else
    echo ""
    echo "$answer"
  fi
}

# Generate images using Imagen 4
generate_images() {
  local prompt="$1"
  local num_images="${2:-4}"
  local output_dir="${3:-$OUTPUT_DIR}"

  check_api_key

  # Create output directory
  mkdir -p "$output_dir"

  local timestamp=$(date +%Y%m%d-%H%M%S)

  log_info "Generating $num_images image(s) with Imagen 4..."
  log_info "Prompt: $prompt"

  # Build request
  local request_body=$(jq -n \
    --arg prompt "$prompt" \
    --argjson num "$num_images" \
    '{
      instances: [{
        prompt: $prompt
      }],
      parameters: {
        sampleCount: $num
      }
    }')

  # Send generation request
  local response=$(curl -s -X POST \
    "${BASE_URL}/models/${MODEL_IMAGE}:predict" \
    -H "x-goog-api-key: ${GEMINI_API_KEY}" \
    -H "Content-Type: application/json" \
    -d "$request_body")

  # Check for errors
  local error=$(echo "$response" | jq -r '.error // empty')
  if [[ -n "$error" ]]; then
    log_error "Generation failed: $(echo "$response" | jq -r '.error.message')"
    echo "$response" | jq . >&2
    return 1
  fi

  # Extract and save images
  local num_predictions=$(echo "$response" | jq '.predictions | length')

  if [[ "$num_predictions" -eq 0 || "$num_predictions" == "null" ]]; then
    log_error "No images returned"
    echo "$response" | jq . >&2
    return 1
  fi

  log_success "Generated $num_predictions image(s)"

  local output_files=()

  for ((i=0; i<num_predictions; i++)); do
    local image_bytes=$(echo "$response" | jq -r ".predictions[$i].image.imageBytes // .predictions[$i].bytesBase64Encoded // empty")

    if [[ -z "$image_bytes" || "$image_bytes" == "null" ]]; then
      log_warning "No image data for prediction $i"
      continue
    fi

    local output_file="${output_dir}/imagen-${timestamp}-${i}.png"

    # Decode base64 and save
    echo "$image_bytes" | base64 -d > "$output_file"

    if [[ -f "$output_file" ]]; then
      log_success "Saved: $output_file ($(du -h "$output_file" | cut -f1))"
      output_files+=("$output_file")
    else
      log_error "Failed to save image $i"
    fi
  done

  if [[ ${#output_files[@]} -gt 0 ]]; then
    echo "${output_files[@]}"
  else
    return 1
  fi
}

# Main command parser
main() {
  if [[ $# -eq 0 ]]; then
    show_help
    exit 1
  fi

  local command="$1"
  local subcommand="${2:-}"

  case "$command" in
    video)
      case "$subcommand" in
        generate)
          shift 2
          local prompt=""
          local negative=""
          local aspect_ratio="$ASPECT_RATIO"
          local resolution="$RESOLUTION"
          local output=""

          while [[ $# -gt 0 ]]; do
            case $1 in
              -p|--prompt)
                prompt="$2"
                shift 2
                ;;
              -n|--negative)
                negative="$2"
                shift 2
                ;;
              -a|--aspect-ratio)
                aspect_ratio="$2"
                shift 2
                ;;
              -r|--resolution)
                resolution="$2"
                shift 2
                ;;
              -o|--output)
                output="$2"
                shift 2
                ;;
              *)
                log_error "Unknown option: $1"
                exit 1
                ;;
            esac
          done

          if [[ -z "$prompt" ]]; then
            log_error "Prompt required (-p)"
            exit 1
          fi

          generate_video "$prompt" "$negative" "$aspect_ratio" "$resolution" "$output"
          ;;
        analyze)
          shift 2
          if [[ $# -eq 0 ]]; then
            log_error "Video file required"
            exit 1
          fi

          local video_file="$1"
          shift
          local question=""
          local output=""

          while [[ $# -gt 0 ]]; do
            case $1 in
              -p|--prompt)
                question="$2"
                shift 2
                ;;
              -o|--output)
                output="$2"
                shift 2
                ;;
              *)
                log_error "Unknown option: $1"
                exit 1
                ;;
            esac
          done

          if [[ -z "$question" ]]; then
            log_error "Question required (-p)"
            exit 1
          fi

          analyze_video "$video_file" "$question" "$output"
          ;;
        *)
          log_error "Unknown video subcommand: $subcommand"
          show_help
          exit 1
          ;;
      esac
      ;;
    image)
      case "$subcommand" in
        generate)
          shift 2
          local prompt=""
          local num_images="$NUM_IMAGES"
          local output_dir="$OUTPUT_DIR"

          while [[ $# -gt 0 ]]; do
            case $1 in
              -p|--prompt)
                prompt="$2"
                shift 2
                ;;
              -n|--num-images)
                num_images="$2"
                shift 2
                ;;
              -o|--output)
                output_dir="$2"
                shift 2
                ;;
              *)
                log_error "Unknown option: $1"
                exit 1
                ;;
            esac
          done

          if [[ -z "$prompt" ]]; then
            log_error "Prompt required (-p)"
            exit 1
          fi

          generate_images "$prompt" "$num_images" "$output_dir"
          ;;
        *)
          log_error "Unknown image subcommand: $subcommand"
          show_help
          exit 1
          ;;
      esac
      ;;
    -h|--help)
      show_help
      exit 0
      ;;
    *)
      log_error "Unknown command: $command"
      show_help
      exit 1
      ;;
  esac
}

main "$@"
