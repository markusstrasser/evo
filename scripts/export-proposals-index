#!/usr/bin/env bash
# Export proposals to TSV/CSV index for easy review
# Usage: scripts/export-proposals-index [proposals-dir] [format]

set -euo pipefail

PROPOSALS_DIR="${1:-}"
FORMAT="${2:-tsv}"

# Auto-detect latest
if [[ -z "$PROPOSALS_DIR" ]]; then
  PROPOSALS_DIR=$(ls -td research/proposals/* 2>/dev/null | head -1)
fi

if [[ -z "$PROPOSALS_DIR" || ! -d "$PROPOSALS_DIR" ]]; then
  echo "Error: No proposals directory found"
  exit 1
fi

OUTPUT_FILE="$PROPOSALS_DIR/proposals-index.$FORMAT"

# Separator
if [[ "$FORMAT" == "csv" ]]; then
  SEP=","
else
  SEP=$'\t'
fi

echo "Exporting proposals from: $PROPOSALS_DIR"
echo "Output: $OUTPUT_FILE"
echo ""

# Extract scores and metadata from rankings
declare -A proposal_scores
declare -A proposal_tiers
declare -A proposal_insights

for ranking in "$PROPOSALS_DIR"/rankings/*.md; do
  [[ ! -f "$ranking" ]] && continue

  current_tier=""
  while IFS= read -r line; do
    # Capture tier
    if [[ "$line" =~ ^###[[:space:]]*Tier[[:space:]]([A-Z]+) ]]; then
      current_tier="${BASH_REMATCH[1]}"
    fi

    # Capture proposal header
    if [[ "$line" =~ ^\*\*Proposal[[:space:]]+([0-9]+):[[:space:]]+([^[:space:]]+) ]]; then
      provider="${BASH_REMATCH[2]}"

      # Read next lines for score, focus area, and insight
      score=""
      question=""
      insight=""
      while IFS= read -r meta_line; do
        [[ "$meta_line" =~ ^-[[:space:]]*Score:[[:space:]]*([0-9]+)/10 ]] && score="${BASH_REMATCH[1]}"
        [[ "$meta_line" =~ ^-[[:space:]]*Focus[[:space:]]Area:[[:space:]]*([^[:space:]]+) ]] && question="${BASH_REMATCH[1]}"
        [[ "$meta_line" =~ ^-[[:space:]]*Core[[:space:]]Insight:[[:space:]]*(.*) ]] && insight="${BASH_REMATCH[1]}"
        [[ "$meta_line" =~ ^\*\* ]] && break  # Next proposal
        [[ -z "$meta_line" ]] && break
      done

      if [[ -n "$score" && -n "$question" ]]; then
        key="${provider}-${question}"
        # Store highest score if multiple rankings
        if [[ -z "${proposal_scores[$key]:-}" || $score -gt ${proposal_scores[$key]} ]]; then
          proposal_scores[$key]=$score
          proposal_tiers[$key]=$current_tier
          proposal_insights[$key]="${insight:0:200}"
        fi
      fi
    fi
  done < "$ranking"
done

# Write header
echo -e "Score${SEP}Tier${SEP}Provider${SEP}Question${SEP}Title${SEP}Core_Insight${SEP}File_Link${SEP}Size_KB" > "$OUTPUT_FILE"

# Process each proposal
for proposal in "$PROPOSALS_DIR"/proposals/*.md; do
  [[ ! -f "$proposal" ]] && continue

  filename=$(basename "$proposal" .md)

  # Parse filename: provider-question
  if [[ "$filename" =~ ^([^-]+)-(.+)$ ]]; then
    provider="${BASH_REMATCH[1]}"
    question="${BASH_REMATCH[2]}"
  else
    provider="unknown"
    question="$filename"
  fi

  key="${provider}-${question}"

  # Get score and tier from rankings
  score="${proposal_scores[$key]:-N/A}"
  tier="${proposal_tiers[$key]:-N/A}"
  insight="${proposal_insights[$key]:-N/A}"

  # Get size in KB
  size_bytes=$(stat -f%z "$proposal" 2>/dev/null || stat -c%s "$proposal" 2>/dev/null)
  size_kb=$((size_bytes / 1024))

  # File link
  abs_path=$(cd "$(dirname "$proposal")" && pwd)/$(basename "$proposal")
  file_link="file://$abs_path"

  # Extract title (first ### or ## heading)
  title=$(grep -m 1 "^###\{1,2\}[[:space:]]" "$proposal" 2>/dev/null | \
          sed 's/^###\{1,2\}[[:space:]]*//' | \
          sed 's/\*\*//g' | \
          head -c 80 || echo "No title")

  # Escape separators
  title="${title//$SEP/ }"
  insight="${insight//$SEP/ }"

  # Write row
  echo -e "${score}${SEP}${tier}${SEP}${provider}${SEP}${question}${SEP}${title}${SEP}${insight}${SEP}${file_link}${SEP}${size_kb}" >> "$OUTPUT_FILE"
done

# Sort by score descending
{
  head -1 "$OUTPUT_FILE"
  tail -n +2 "$OUTPUT_FILE" | sort -t"$SEP" -k1 -rn
} > "$OUTPUT_FILE.sorted"
mv "$OUTPUT_FILE.sorted" "$OUTPUT_FILE"

count=$(tail -n +2 "$OUTPUT_FILE" | wc -l | tr -d ' ')
echo "✓ Exported $count proposals to:"
echo "  $OUTPUT_FILE"
echo ""
echo "View with:"
echo "  open '$OUTPUT_FILE'  # Default app"
echo "  Numbers, Excel, or any TSV/CSV viewer"
