#!/bin/bash
# Validate that the architectural proposals workflow is properly configured
# Usage: scripts/validate-proposal-setup

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "=== Architectural Proposals Setup Validation ==="
echo ""

errors=0
warnings=0

# Check files exist
echo "Checking required files..."

files=(
  "docs/2025-09-30-19-34-src-overview.md:Overview"
  "research/architectural-questions.edn:Questions"
  "research/proposal-ranker-prompt.md:Ranker Prompt"
  "scripts/architectural-proposals:Main Script"
  "scripts/grok:Grok Wrapper"
  "research/ARCHITECTURAL_PROPOSALS.md:Documentation"
  "research/CLI_REFERENCE.md:CLI Reference"
)

for file_desc in "${files[@]}"; do
  file="${file_desc%%:*}"
  desc="${file_desc#*:}"

  if [[ -f "$file" ]]; then
    echo -e "  ${GREEN}✓${NC} $desc: $file"
  else
    echo -e "  ${RED}✗${NC} $desc: $file (MISSING)"
    errors=$((errors + 1))
  fi
done

echo ""

# Check executables
echo "Checking executables..."

if [[ -x "scripts/architectural-proposals" ]]; then
  echo -e "  ${GREEN}✓${NC} scripts/architectural-proposals is executable"
else
  echo -e "  ${RED}✗${NC} scripts/architectural-proposals not executable"
  errors=$((errors + 1))
fi

if [[ -x "scripts/grok" ]]; then
  echo -e "  ${GREEN}✓${NC} scripts/grok is executable"
else
  echo -e "  ${RED}✗${NC} scripts/grok not executable"
  errors=$((errors + 1))
fi

echo ""

# Check CLI tools
echo "Checking CLI tools..."

if command -v gemini &> /dev/null; then
  echo -e "  ${GREEN}✓${NC} gemini CLI installed"
else
  echo -e "  ${YELLOW}⚠${NC} gemini CLI not found (proposals will be incomplete)"
  warnings=$((warnings + 1))
fi

if command -v codex &> /dev/null; then
  echo -e "  ${GREEN}✓${NC} codex CLI installed"
else
  echo -e "  ${YELLOW}⚠${NC} codex CLI not found (proposals will be incomplete)"
  warnings=$((warnings + 1))
fi

if command -v jq &> /dev/null; then
  echo -e "  ${GREEN}✓${NC} jq installed (required for grok)"
else
  echo -e "  ${RED}✗${NC} jq not found (required for grok wrapper)"
  errors=$((errors + 1))
fi

echo ""

# Check API keys
echo "Checking API keys..."

if [[ -n "${GROK_API_KEY:-}" ]]; then
  echo -e "  ${GREEN}✓${NC} GROK_API_KEY is set"
else
  echo -e "  ${YELLOW}⚠${NC} GROK_API_KEY not set (grok will be skipped)"
  warnings=$((warnings + 1))
fi

echo ""

# Check output directory
echo "Checking output directory..."

if [[ -d "research/proposals" ]]; then
  echo -e "  ${GREEN}✓${NC} research/proposals/ exists"
else
  echo -e "  ${YELLOW}⚠${NC} research/proposals/ does not exist (will be created)"
  warnings=$((warnings + 1))
fi

echo ""

# Summary
echo "=== Summary ==="
echo ""

if [[ $errors -eq 0 && $warnings -eq 0 ]]; then
  echo -e "${GREEN}✓ All checks passed!${NC}"
  echo ""
  echo "Ready to run: scripts/architectural-proposals"
  exit 0
elif [[ $errors -eq 0 ]]; then
  echo -e "${YELLOW}⚠ $warnings warning(s)${NC}"
  echo ""
  echo "You can run: scripts/architectural-proposals"
  echo "Some providers may be skipped."
  exit 0
else
  echo -e "${RED}✗ $errors error(s), $warnings warning(s)${NC}"
  echo ""
  echo "Please fix errors before running scripts/architectural-proposals"
  exit 1
fi
