{
  "name": "evolver",
  "version": "0.0.1",
  "scripts": {
    "start": "node scripts/watch-runner.mjs",
    "clean": "npx shadow-cljs clean && bb clean",
    "dev": "npm run clean && concurrently --kill-others-on-fail --names \"CLJS,CSS\" --prefix-colors \"blue,green\" \"npm run watch:cljs\" \"npm run watch:css\"",
    "dev:fast": "concurrently --kill-others-on-fail --names \"CLJS,CSS\" --prefix-colors \"blue,green\" \"npm run watch:cljs\" \"npm run watch:css\"",
    "watch": "npm run dev:fast",
    "watch:clean": "npm run clean && npm run dev:fast",
    "watch:cljs": "npx shadow-cljs watch blocks-ui",
    "watch:css": "tailwindcss -i input.css -o public/output.css --watch",
    "compile": "npx shadow-cljs compile blocks-ui",
    "build": "npm run clean && npx shadow-cljs release blocks-ui && tailwindcss -i input.css -o public/output.css --minify",
    "lint": "npm run lint:clj && npm run lint:js && npm run lint:e2e-keyboard",
    "lint:clj": "bb lint",
    "lint:js": "biome check .",
    "lint:js:fix": "biome check --write .",
    "format:js": "biome format --write .",
    "lint:fr": "bb fr-audit",
    "lint:fr-coverage": "bb lint:fr-tests",
    "lint:scenarios": "bb lint:scenarios",
    "lint:e2e-keyboard": "node scripts/lint-e2e-keyboard.js",
    "test": "bb test",
    "test:unit": "bb test",
    "test:view": "bb test:view",
    "test:e2e": "PLAYWRIGHT_HEADLESS=true npx playwright test",
    "test:e2e:headless": "PLAYWRIGHT_HEADLESS=true npx playwright test",
    "test:e2e:headed": "PLAYWRIGHT_HEADLESS=false npx playwright test",
    "test:e2e:debug": "PLAYWRIGHT_HEADLESS=false npx playwright test --debug",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:chromium": "PLAYWRIGHT_HEADLESS=true npx playwright test --project=chromium",
    "test:all": "npm run test:unit && npm run test:e2e",
    "kb:thin": "uv run ~/Projects/best/thin_repos.py"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@biomejs/biome": "^2.3.6",
    "@percy/playwright": "^1.0.9",
    "@playwright/test": "^1.56.0",
    "@tailwindcss/cli": "^4.1.14",
    "concurrently": "^9.2.1",
    "shadow-cljs": "^3.2.0",
    "tailwindcss": "^4.1.14"
  },
  "dependencies": {
    "three": "^0.180.0"
  }
}
