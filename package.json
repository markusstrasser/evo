{
  "name": "evolver",
  "version": "0.0.1",
  "scripts": {
    "start": "node scripts/watch-runner.mjs",
    "clean": "rm -rf .shadow-cljs .cpcache out public/js/blocks-ui public/js/spec-viewer",
    "dev": "npm run clean && npm run watch:cljs",
    "dev:fast": "npm run watch:cljs",
    "watch": "npm run dev:fast",
    "watch:clean": "npm run clean && npm run dev:fast",
    "watch:cljs": "npx shadow-cljs watch blocks-ui",
    "compile": "npx shadow-cljs compile blocks-ui",
    "compile:specs": "npx shadow-cljs compile spec-viewer",
    "build": "npm run clean && npx shadow-cljs release blocks-ui && npx shadow-cljs release spec-viewer",
    "build:specs": "npx shadow-cljs release spec-viewer",
    "lint": "npm run lint:clj && npm run lint:js && npm run lint:e2e-keyboard && npm run lint:e2e-contracts",
    "lint:clj": "bb lint",
    "lint:js": "biome check .",
    "lint:js:fix": "biome check --write .",
    "format:js": "biome format --write .",
    "lint:fr": "bb fr-audit",
    "lint:fr-coverage": "bb lint:fr-tests",
    "lint:e2e-keyboard": "node scripts/lint-e2e-keyboard.js",
    "lint:e2e-contracts": "node scripts/lint-e2e-contracts.js",
    "test": "bb test",
    "test:unit": "bb test",
    "test:view": "bb test:view",
    "test:e2e": "PLAYWRIGHT_HEADLESS=true npx playwright test",
    "test:e2e:headless": "PLAYWRIGHT_HEADLESS=true npx playwright test",
    "test:e2e:headed": "PLAYWRIGHT_HEADLESS=false npx playwright test",
    "test:e2e:debug": "PLAYWRIGHT_HEADLESS=false npx playwright test --debug",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:smoke": "PLAYWRIGHT_HEADLESS=true npx playwright test --project=smoke",
    "test:e2e:chromium": "PLAYWRIGHT_HEADLESS=true npx playwright test --project=chromium",
    "test:all": "npm run test:unit && npm run test:e2e"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@playwright/test": "^1.59.1",
    "shadow-cljs": "^3.4.4"
  },
  "dependencies": {
    "turndown": "^7.2.4"
  }
}
