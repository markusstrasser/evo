{
  "name": "evolver",
  "version": "0.0.1",
  "scripts": {
    "dev": "npx shadow-cljs watch app test",
    "build": "npx shadow-cljs release app",
    "test": "npx shadow-cljs compile test && node out/tests.js",
    "check": "npm run check:lint && npm run check:compile",
    "check:lint": "clj-kondo --lint src test --fail-level error",
    "check:compile": "npx shadow-cljs compile test",
    "fix:cache": "npx shadow-cljs clean && rm -rf .shadow-cljs out target .cpcache node_modules/.cache",
    "agent:health": "dev/scripts/health-check.sh",
    "agent:preflight": "dev/scripts/preflight.sh",
    "repl:health": "clj -M:dev -e '(require \"[session :as s]\") (s/quick-health-check!)'"
  },
  "devDependencies": {
    "shadow-cljs": "^2.28.10"
  },
  "dependencies": {}
}
