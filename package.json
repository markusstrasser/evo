{
  "name": "evolver",
  "version": "0.0.1",
  "scripts": {
    "dev": "npx shadow-cljs watch app test",
    "build": "npx shadow-cljs release app",
    "test": "npx shadow-cljs compile test && node out/tests.js",
    "lint": "clj-kondo --lint src test --fail-level error",
    "lint:fresh": "rm -rf .clj-kondo/.cache && clj-kondo --lint src test --fail-level error",
    "check": "clj-kondo --lint src test --fail-level error && npx shadow-cljs compile test",
    "fix:cache": "npx shadow-cljs clean && rm -rf .shadow-cljs out target .cpcache node_modules/.cache",
    "agent:health": "dev/bin/health-check.sh",
    "agent:preflight": "dev/bin/preflight.sh",
    "repl:health": "clj -M:dev -e '(require (quote [repl.session :as s])) (s/quick-health-check!)'",
    "docs:overview": "scripts/generate-overview.sh --source",
    "kb:thin": "uv run ~/Projects/best/thin_repos.py"
  },
  "devDependencies": {
    "shadow-cljs": "^3.2.0"
  },
  "dependencies": {}
}
