{
  "name": "evolver",
  "version": "0.0.1",
  "scripts": {
    "start": "npm run dev",
    "dev": "concurrently --kill-others-on-fail \"npm run watch:cljs\" \"npm run watch:css\"",
    "watch:cljs": "npx shadow-cljs watch anki",
    "watch:css": "tailwindcss -i input.css -o public/output.css --watch",
    "build": "npx shadow-cljs clean && npx shadow-cljs release anki && tailwindcss -i input.css -o public/output.css --minify",
    "kb:thin": "uv run ~/Projects/best/thin_repos.py"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@percy/playwright": "^1.0.9",
    "@playwright/test": "^1.56.0",
    "@tailwindcss/cli": "^4.1.14",
    "concurrently": "^9.2.1",
    "shadow-cljs": "^3.2.0",
    "tailwindcss": "^4.1.14"
  },
  "dependencies": {
    "three": "^0.180.0"
  }
}
