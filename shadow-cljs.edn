;; shadow-cljs configuration
;; Dependencies and paths are sourced from deps.edn (single source of truth)
{:deps true

 :dev-http {8080 ["public" "dev"]}

 :nrepl {:port 55449}
 :builds
  {:blocks-ui
  {:target :browser
   :output-dir "public/js/blocks-ui"
   :asset-path "/js/blocks-ui"
   :modules {:main {:init-fn shell.editor/main}}
   :devtools {:reload-strategy :full ;; Force full page reload to prevent stale state
              :watch-dir "public"} ;; Hot-reload CSS when output.css changes
   :preloads [debug]}

  :spec-viewer
  {:target :browser
   :output-dir "public/js/spec-viewer"
   :asset-path "/js/spec-viewer"
   :modules {:main {:init-fn shell.spec-viewer/main}}
   :devtools {:reload-strategy :full
              :watch-dir "public"}}

  :test
  {:target :node-test
   :output-to "out/tests.js"
   :ns-regexp "-test$"
   :ns-exclude-regexp "browser-ui"}

  :test-view
  {:target :node-test
   :output-to "out/tests-view.js"
   :ns-regexp "^view\\..*-test$"}

  :test-integration
  {:target :node-test
   :output-to "out/tests-integration.js"
   :ns-regexp "^integration\\..*-test$"}

  :test-kernel
  {:target :node-test
   :output-to "out/tests-kernel.js"
   :ns-regexp "^(kernel|scripts)\\..*-test$"}

  :test-specs
  {:target :node-test
   :output-to "out/tests-specs.js"
   :ns-regexp "^spec\\..*-test$"}

  :test-fr-fixtures
  {:target :node-test
   :output-to "out/tests-fr-fixtures.js"
   :ns-regexp "^property\\.fr-fixtures-test$"}}}
