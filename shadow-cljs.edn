;; shadow-cljs configuration
;; Dependencies and paths are sourced from deps.edn (single source of truth)
{:deps true

 :dev-http {8080 ["public" "dev"]}

 :nrepl {:port 55449}
 :compiler-options {:externs ["datascript/externs.js"]}
 :builds
 {:frontend
  {:target :browser
   :modules {:main {:init-fn shell.main/main}}}

  :blocks-ui
  {:target :browser
   :output-dir "public/js/blocks-ui"
   :asset-path "/js/blocks-ui"
   :modules {:main {:init-fn shell.editor/main}}
   :preloads [debug]}

  :test
  {:target :node-test
   :output-to "out/tests.js"
   :ns-regexp "-test$"
   :ns-exclude-regexp "browser-ui"}

  :test-view
  {:target :node-test
   :output-to "out/tests-view.js"
   :ns-regexp "^view\\..*-test$"}

  :test-integration
  {:target :node-test
   :output-to "out/tests-integration.js"
   :ns-regexp "^integration\\.navigation.*-test$"}

  :test-specs
  {:target :node-test
   :output-to "out/tests-specs.js"
   :ns-regexp "^spec\\..*-test$"}}}
