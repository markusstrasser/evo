 :fr.edit/delete-forward
 {:desc "Delete key removes character at cursor or merges with next block at end"
  :priority :high
  :type :intent-level
  :status :active
  :version 1
  :tags [:editing]
  :spec-ref "LOGSEQ_SPEC.md §4 FR-Edit-03"
  :level :intent

  :behaviors
  [{:context "Cursor in middle of text"
    :behavior "Delete character after cursor"
    :scenario :DELETE-CHAR}
