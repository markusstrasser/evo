{;; Navigation: Editing mode
 :fr.nav/vertical-cursor-memory
 {:desc "Vertical navigation preserves horizontal grapheme column across blocks"
  :priority :critical
  :type :intent-level
  :status :active
  :version 1
  :tags [:navigation :editing :cursor]
  :spec-ref "LOGSEQ_SPEC.md §2.1"
  :level :intent

  :behaviors
  [{:context "ArrowDown in edit mode"
    :behavior "Move to next block, restore saved column or clamp to line length"
    :scenario :NAV-DOWN-MEMORY}
   {:context "ArrowUp in edit mode"
    :behavior "Move to previous block, restore saved column or clamp to line length"
    :scenario :NAV-UP-MEMORY}
   {:context "Column exceeds target line length"
    :behavior "Clamp to end of line, but remember original column"
    :scenario :NAV-CLAMP-COLUMN}]

  :scenarios
  {:NAV-DOWN-MEMORY
   {:name "ArrowDown moves to next block, clamping to line end"
    :tags #{:happy-path :critical}
    :setup {:tree [:doc
                   [:a "Hello World" {:cursor 6}]
                   [:b "Short"]]}
    :action {:type :navigate-with-cursor-memory
             :direction :down
             :current-block-id "a"
             :current-text "Hello World"
             :current-cursor-pos 6}
    ;; Cursor 6 > length of "Short" (5), so kernel returns :end
    :expect {:tree [:doc
                    [:a "Hello World"]
                    [:b "Short" {:cursor :end}]]}}

   :NAV-UP-MEMORY
   {:name "ArrowUp preserves cursor column"
    :tags #{:happy-path}
    :setup {:tree [:doc
                   [:a "First line"]
                   [:b "Second line" {:cursor 7}]]}
    :action {:type :navigate-with-cursor-memory
             :direction :up
             :current-block-id "b"
             :current-text "Second line"
             :current-cursor-pos 7}
    :expect {:tree [:doc
                    [:a "First line" {:cursor 7}]
                    [:b "Second line"]]}}

   :NAV-CLAMP-COLUMN
   {:name "Column clamped to :end when target shorter"
    :tags #{:edge-case}
    :setup {:tree [:doc
                   [:a "Very long line here" {:cursor 15}]
                   [:b "Short"]]}
    :action {:type :navigate-with-cursor-memory
             :direction :down
             :current-block-id "a"
             :current-text "Very long line here"
             :current-cursor-pos 15}
    ;; Cursor 15 > length of "Short" (5), so kernel returns :end
    :expect {:tree [:doc
                    [:a "Very long line here"]
                    [:b "Short" {:cursor :end}]]}}

   ;; Legacy scenario IDs
   :NAV-CURSOR-MEMORY-01 {:name "Legacy: cursor memory" :tags #{:legacy}}
   :NAV-EMACS-PN-01 {:name "Legacy: Ctrl+P/N navigation" :tags #{:legacy}}}}

 :fr.nav/horizontal-boundary
 {:desc "ArrowLeft at column 0 / ArrowRight at end jumps to adjacent block"
  :priority :high
  :type :intent-level
  :status :active
  :version 1
  :tags [:navigation :editing]
  :spec-ref "LOGSEQ_SPEC.md §2.3"

  :behaviors
  [{:context "Editing block, cursor at column 0, ArrowLeft pressed"
    :behavior "Jump to end of previous block"
    :scenario :LEFT-AT-START}
   {:context "Editing block, cursor at end of text, ArrowRight pressed"
    :behavior "Jump to start of next block"
    :scenario :RIGHT-AT-END}
   {:context "First block in document, cursor at column 0, ArrowLeft pressed"
    :behavior "No-op (already at document boundary)"
    :scenario :LEFT-AT-DOC-START}
   {:context "Last block in document, cursor at end, ArrowRight pressed"
    :behavior "No-op (already at document boundary)"
    :scenario :RIGHT-AT-DOC-END}]

  :scenarios
  {:LEFT-AT-START
   {:name "ArrowLeft at column 0 jumps to previous block end"
    :setup {:tree [:doc
                   [:a "First block"]
                   [:b "Second block" {:cursor 0}]]}
    :action {:type :navigate-to-adjacent
             :direction :up
             :current-block-id "b"
             :cursor-position :max}
    :expect {:tree [:doc
                    [:a "First block" {:cursor :end}]
                    [:b "Second block"]]}}

   :RIGHT-AT-END
   {:name "ArrowRight at text end jumps to next block start"
    :setup {:tree [:doc
                   [:a "First block" {:cursor :end}]
                   [:b "Second block"]]}
    :action {:type :navigate-to-adjacent
             :direction :down
             :current-block-id "a"
             :cursor-position 0}
    :expect {:tree [:doc
                    [:a "First block"]
                    [:b "Second block" {:cursor 0}]]}}

   :LEFT-AT-DOC-START
   {:name "ArrowLeft at first block is no-op"
    :setup {:tree [:doc
                   [:a "Only block" {:cursor 0}]]}
    :action {:type :navigate-to-adjacent
             :direction :up
             :current-block-id "a"
             :cursor-position :max}
    ;; No previous block exists, so cursor stays where it is
    :expect {:tree [:doc
                    [:a "Only block" {:cursor 0}]]}}

   :RIGHT-AT-DOC-END
   {:name "ArrowRight at last block is no-op"
    :setup {:tree [:doc
                   [:a "Only block" {:cursor :end}]]}
    :action {:type :navigate-to-adjacent
             :direction :down
             :current-block-id "a"
             :cursor-position 0}
    ;; No next block exists, so cursor stays where it is
    :expect {:tree [:doc
                    [:a "Only block" {:cursor :end}]]}}}}

 ;; Navigation: View mode
 :fr.nav/view-arrows
 {:desc "ArrowUp/Down in view mode moves focus through visible siblings, skipping folded blocks"
  :priority :critical
  :type :intent-level
  :status :active
  :version 1
  :tags [:navigation :selection]
  :spec-ref "LOGSEQ_SPEC.md §2.2"
  :level :intent

  :behaviors
  [{:context "Block selected, ArrowDown pressed"
    :behavior "Move selection to next visible sibling"
    :scenario :NAV-DOWN}
   {:context "Block selected, ArrowUp pressed"
    :behavior "Move selection to previous visible sibling"
    :scenario :NAV-UP}
   {:context "Folded block in path"
    :behavior "Skip folded blocks and their children"
    :scenario :SKIP-FOLDED}]

  :scenarios
  {:NAV-DOWN
   {:name "ArrowDown moves selection to next block"
    :tags #{:happy-path :critical}
    :setup {:tree [:doc
                   [:a "First" {:selected? true :focus? true}]
                   [:b "Second"]
                   [:c "Third"]]}
    :action {:type :selection :mode :next}
    :expect {:tree [:doc
                    [:a "First"]
                    [:b "Second" {:selected? true :focus? true}]
                    [:c "Third"]]}}

   :NAV-UP
   {:name "ArrowUp moves selection to previous block"
    :tags #{:happy-path}
    :setup {:tree [:doc
                   [:a "First"]
                   [:b "Second" {:selected? true :focus? true}]
                   [:c "Third"]]}
    :action {:type :selection :mode :prev}
    :expect {:tree [:doc
                    [:a "First" {:selected? true :focus? true}]
                    [:b "Second"]
                    [:c "Third"]]}}}}

 :fr.nav/idle-first-last
 {:desc "ArrowDown/Up from idle state selects first/last visible block"
  :priority :high
  :type :intent-level
  :status :active
  :version 1
  :tags [:navigation :idle]
  :spec-ref "LOGSEQ_SPEC.md §2.2"
  :level :intent

  :behaviors
  [{:context "Idle state (no selection, no editing), ArrowDown pressed"
    :behavior "Select first visible block"
    :scenario :IDLE-DOWN-FIRST}
   {:context "Idle state (no selection, no editing), ArrowUp pressed"
    :behavior "Select last visible block"
    :scenario :IDLE-UP-LAST}]

  :scenarios
  {:IDLE-DOWN-FIRST
   {:name "ArrowDown from idle selects first block"
    :tags #{:happy-path}
    :setup {:tree [:doc [:a "First"] [:b "Second"] [:c "Third"]]
            :session {:selection {:nodes #{}}}}
    :action {:type :selection :mode :next}
    :expect {:tree [:doc
                    [:a "First" {:selected? true :focus? true}]
                    [:b "Second"]
                    [:c "Third"]]}}

   :IDLE-UP-LAST
   {:name "ArrowUp from idle selects last block"
    :tags #{:happy-path}
    :setup {:tree [:doc [:a "First"] [:b "Second"] [:c "Third"]]
            :session {:selection {:nodes #{}}}}
    :action {:type :selection :mode :prev}
    :expect {:tree [:doc
                    [:a "First"]
                    [:b "Second"]
                    [:c "Third" {:selected? true :focus? true}]]}}}}

 ;; Selection
 :fr.selection/extend-boundary
 {:desc "Shift+Arrow extends selection incrementally with direction tracking"
  :priority :critical
  :type :intent-level
  :status :active
  :version 1
  :tags [:selection :keyboard]
  :spec-ref "LOGSEQ_SPEC.md §3"
  :level :intent

  :behaviors
  [{:context "Single block selected, Shift+Down"
    :behavior "Extend selection to include next sibling"
    :scenario :EXTEND-DOWN}
   {:context "Multiple blocks selected, Shift+Up shrinks from focus direction"
    :behavior "Contract selection from focus end"
    :scenario :CONTRACT-SELECTION}
   {:context "At boundary (first/last block)"
    :behavior "No-op when no more blocks in direction"
    :scenario :EXTEND-BOUNDARY-NOOP}]

  :scenarios
  {:EXTEND-DOWN
   {:name "Shift+Down extends selection to next block"
    :tags #{:happy-path :critical}
    :setup {:tree [:doc
                   [:a "First" {:selected? true :focus? true}]
                   [:b "Second"]
                   [:c "Third"]]}
    :action {:type :selection :mode :extend-next}
    :expect {:tree [:doc
                    [:a "First" {:selected? true}]
                    [:b "Second" {:selected? true :focus? true}]
                    [:c "Third"]]}}

   :EXTEND-UP
   {:name "Shift+Up extends selection to previous block"
    :tags #{:happy-path}
    :setup {:tree [:doc
                   [:a "First"]
                   [:b "Second" {:selected? true :focus? true}]
                   [:c "Third"]]}
    :action {:type :selection :mode :extend-prev}
    :expect {:tree [:doc
                    [:a "First" {:selected? true :focus? true}]
                    [:b "Second" {:selected? true}]
                    [:c "Third"]]}}}}

 :fr.selection/edit-view-exclusive
 {:desc "Edit mode and selection state never coexist; transitions clear opposite state"
  :priority :critical
  :type :invariant
  :status :active
  :version 1
  :tags [:state-machine :editing :selection]
  :spec-ref "LOGSEQ_SPEC.md §1.1"
  :level :kernel

  :behaviors
  [{:context "Entering edit mode while blocks selected"
    :behavior "Clear selection before editing"
    :scenario :EDIT-CLEARS-SELECTION}
   {:context "Selecting block while in edit mode"
    :behavior "Exit edit mode before selecting"
    :scenario :SELECT-EXITS-EDIT}]

  :invariants
  {:pre [:editing-xor-selection]
   :post [:editing-xor-selection]}

  :scenarios
  {:EDIT-CLEARS-SELECTION
   {:name "Entering edit mode clears selection"
    :tags #{:invariant :critical}
    :setup {:tree [:doc
                   [:a "First" {:selected? true :focus? true}]
                   [:b "Second"]]}
    :action {:type :enter-edit :block-id "b" :cursor-at :end}
    :expect {:tree [:doc
                    [:a "First"]
                    [:b "Second" {:cursor :_}]]
             :session {:selection {:nodes #{}}}}}

   :SELECT-EXITS-EDIT
   {:name "Selecting block exits edit mode"
    :tags #{:invariant :critical}
    :setup {:tree [:doc
                   [:a "First" {:cursor 0}]
                   [:b "Second"]]}
    :action {:type :selection :mode :replace :ids ["b"]}
    :expect {:tree [:doc
                    [:a "First"]
                    [:b "Second" {:selected? true :focus? true}]]}}}}

 :fr.selection/cmd-a-cycle
 {:desc "Cmd+A cycles: select all text → select block → select parent → select all visible"
  :priority :high
  :type :intent-level
  :status :active
  :version 1
  :tags [:selection :keyboard]
  :spec-ref "LOGSEQ_SPEC.md §7.2"
  :level :intent

  :behaviors
  [{:context "Editing with all text selected"
    :behavior "Exit edit mode, select the block"
    :scenario :CYCLE-TO-BLOCK}
   {:context "Single block selected"
    :behavior "Select parent (if exists), else select all visible"
    :scenario :CYCLE-TO-PARENT}
   {:context "Parent or multiple blocks selected"
    :behavior "Select all visible blocks"
    :scenario :CYCLE-TO-ALL}]

  :scenarios
  {:CYCLE-TO-BLOCK
   {:name "Cmd+A from editing selects the block"
    :tags #{:happy-path}
    :setup {:tree [:doc [:a "Hello" {:cursor 0}] [:b "World"]]}
    :action {:type :select-all-cycle :from-editing? true :block-id "a"}
    :expect {:tree [:doc
                    [:a "Hello" {:selected? true :focus? true}]
                    [:b "World"]]}}

   :CYCLE-TO-PARENT
   {:name "Cmd+A on single block selects parent"
    :tags #{:happy-path}
    :setup {:tree [:doc
                   [:a "Parent"
                    [:b "Child" {:selected? true :focus? true}]]]}
    :action {:type :select-all-cycle}
    :expect {:tree [:doc
                    [:a "Parent" {:selected? true :focus? true}
                     [:b "Child"]]]}}

   :CYCLE-TO-ALL
   {:name "Cmd+A on parent selects all visible"
    :tags #{:happy-path}
    :setup {:tree [:doc
                   [:a "First" {:selected? true :focus? true}]
                   [:b "Second"]]}
    :action {:type :select-all-cycle}
    :expect {:tree [:doc
                    [:a "First" {:selected? true}]
                    [:b "Second" {:selected? true :focus? true}]]}}}}

 ;; Editing
 :fr.edit/smart-split
 {:desc "Enter performs context-aware split; empty list items unformat + create peer in single step"
  :priority :critical
  :type :intent-level
  :status :active
  :version 1
  :tags [:editing :smart-editing]
  :spec-ref "LOGSEQ_SPEC.md §4"
  :level :intent

  :behaviors
  [{:context "Cursor in middle of text"
    :behavior "Split block at cursor: text before stays, text after goes to new sibling"
    :scenario :SPLIT-MIDDLE}
   {:context "Cursor at position 0"
    :behavior "Create empty block ABOVE current block"
    :scenario :SPLIT-AT-START}
   {:context "Empty list marker (e.g. '- ')"
    :behavior "Unformat list + create peer block after parent"
    :scenario :EMPTY-LIST-UNFORMAT}]

  :scenarios
  {:SPLIT-MIDDLE
   {:name "Split block at cursor position"
    :tags #{:happy-path :critical}
    :setup {:tree [:doc
                   [:a "Hello World" {:cursor 5}]]}
    :action {:type :context-aware-enter
             :block-id "a"
             :cursor-pos 5}
    :expect {:tree [:doc
                    [:a "Hello"]
                    [:new "World"]]}}

   :SPLIT-AT-START
   {:name "Enter at position 0 creates block above"
    :tags #{:edge-case}
    :setup {:tree [:doc
                   [:a "Content" {:cursor 0}]]}
    :action {:type :context-aware-enter
             :block-id "a"
             :cursor-pos 0}
    :expect {:tree [:doc
                    [:new ""]
                    [:a "Content"]]}}}}

 :fr.edit/backspace-merge
 {:desc "Backspace at start merges into previous sibling, re-parents children, preserves caret"
  :priority :critical
  :type :intent-level
  :status :active
  :version 1
  :tags [:editing :merge]
  :spec-ref "LOGSEQ_SPEC.md §4"
  :level :intent

  :behaviors
  [{:context "Cursor = 0, has previous sibling"
    :behavior "Merge into previous block, re-parent children"
    :scenario :MERGE-SIBLING}
   {:context "Cursor = 0, first child (no prev sibling)"
    :behavior "Merge into parent block"
    :scenario :MERGE-PARENT}
   {:context "Empty block"
    :behavior "Delete block, focus previous"
    :scenario :DELETE-EMPTY}]

  :scenarios
  {:MERGE-SIBLING
   {:name "Merge with previous sibling"
    :tags #{:happy-path :critical}
    :setup {:tree [:doc
                   [:a "Hello"]
                   [:b "World" {:cursor 0}]]}
    :action {:type :merge-with-prev :block-id "b"}
    :expect {:tree [:doc
                    [:a "HelloWorld" {:cursor 5}]]}}

   :MERGE-WITH-CHILDREN
   {:name "Merge re-parents children to target"
    :tags #{:edge-case}
    :setup {:tree [:doc
                   [:a "First"]
                   [:b "Second" {:cursor 0}
                    [:c "Child"]]]}
    :action {:type :merge-with-prev :block-id "b"}
    :expect {:tree [:doc
                    [:a "FirstSecond" {:cursor 5}
                     [:c "Child"]]]}}

   ;; Legacy scenario IDs for backward compat
   :EDIT-BACKSPACE-MERGE-01 {:name "Legacy: basic merge" :tags #{:legacy}
                             :setup {:tree [:doc [:a "A"] [:b "B" {:cursor 0}]]}
                             :action {:type :merge-with-prev :block-id "b"}
                             :expect {:tree [:doc [:a "AB" {:cursor 1}]]}}}}

 ;; Structural
 :fr.struct/indent-outdent
 {:desc "Tab/Shift+Tab moves blocks under previous sibling / after parent; guards zoom roots"
  :priority :critical
  :type :intent-level
  :status :active
  :version 1
  :tags [:structural :tree]
  :spec-ref "LOGSEQ_SPEC.md §5.1"
  :level :intent

  :behaviors
  [{:context "Has previous sibling"
    :behavior "Tab makes block last child of previous sibling"
    :scenario :INDENT-BASIC}
   {:context "First child (no prev sibling)"
    :behavior "Tab is no-op"
    :scenario :INDENT-NOOP}
   {:context "Has parent (not at doc level)"
    :behavior "Shift+Tab makes block sibling of parent, after parent"
    :scenario :OUTDENT-BASIC}
   {:context "At doc level"
    :behavior "Shift+Tab is no-op"
    :scenario :OUTDENT-NOOP}]

  :scenarios
  {:INDENT-BASIC
   {:name "Indent makes block child of previous sibling"
    :tags #{:happy-path :critical}
    :setup {:tree [:doc
                   [:a "First"]
                   [:b "Second" {:selected? true}]]}
    :action {:type :indent-selected}
    :expect {:tree [:doc
                    [:a "First"
                     [:b "Second" {:selected? true}]]]}}

   :INDENT-WITH-CHILDREN
   {:name "Indent preserves block's children"
    :tags #{:edge-case}
    :setup {:tree [:doc
                   [:a "Parent"]
                   [:b "Has Kids" {:selected? true}
                    [:c "Child"]]]}
    :action {:type :indent-selected}
    :expect {:tree [:doc
                    [:a "Parent"
                     [:b "Has Kids" {:selected? true}
                      [:c "Child"]]]]}}

   :INDENT-NOOP
   {:name "Indent no-op when first child"
    :tags #{:boundary}
    :setup {:tree [:doc
                   [:a "Only block" {:selected? true}]]}
    :action {:type :indent-selected}
    :expect {:tree [:doc
                    [:a "Only block" {:selected? true}]]
             :ops {:count 0}}}

   :OUTDENT-BASIC
   {:name "Outdent moves block to parent's level"
    :tags #{:happy-path :critical}
    :setup {:tree [:doc
                   [:a "Parent"
                    [:b "Child" {:selected? true}]]]}
    :action {:type :outdent-selected}
    :expect {:tree [:doc
                    [:a "Parent"]
                    [:b "Child" {:selected? true}]]}}

   :OUTDENT-WITH-CHILDREN
   {:name "Outdent preserves block's children"
    :tags #{:edge-case}
    :setup {:tree [:doc
                   [:a "Grandparent"
                    [:b "Parent" {:selected? true}
                     [:c "Child"]]]]}
    :action {:type :outdent-selected}
    :expect {:tree [:doc
                    [:a "Grandparent"]
                    [:b "Parent" {:selected? true}
                     [:c "Child"]]]}}

   :OUTDENT-NOOP
   {:name "Outdent no-op at doc level"
    :tags #{:boundary}
    :setup {:tree [:doc
                   [:a "Top level" {:selected? true}]]}
    :action {:type :outdent-selected}
    :expect {:tree [:doc
                    [:a "Top level" {:selected? true}]]
             :ops {:count 0}}}}}

 :fr.struct/climb-descend
 {:desc "Cmd+Shift+Up/Down at boundaries climbs out to parent level / descends into next sibling"
  :priority :high
  :type :intent-level
  :status :active
  :version 1
  :tags [:structural :move]
  :spec-ref "LOGSEQ_SPEC.md §5.2"
  :level :intent

  :behaviors
  [{:context "First child, Cmd+Shift+Up"
    :behavior "Climb out: move before parent (become sibling of parent)"
    :scenario :CLIMB-OUT}
   {:context "Last child, Cmd+Shift+Down"
    :behavior "Descend: move into parent's next sibling as first child"
    :scenario :DESCEND-INTO}
   {:context "At doc level (top-level block)"
    :behavior "No-op (can't climb further)"
    :scenario :CLIMB-BOUNDARY}]

  :scenarios
  {:CLIMB-OUT
   {:name "Cmd+Shift+Up on first child climbs out to parent level"
    :tags #{:critical :happy-path}
    :setup {:tree [:doc
                   [:a "Parent"
                    [:b "First child" {:selected? true}]
                    [:c "Second child"]]]}
    :action {:type :move-selected-up}
    :expect {:tree [:doc
                    [:b "First child" {:selected? true}]
                    [:a "Parent"
                     [:c "Second child"]]]}}

   :DESCEND-INTO
   {:name "Cmd+Shift+Down on last child descends into uncle"
    :tags #{:happy-path}
    :setup {:tree [:doc
                   [:a "Parent"
                    [:b "Last child" {:selected? true}]]
                   [:c "Uncle"]]}
    :action {:type :move-selected-down}
    :expect {:tree [:doc
                    [:a "Parent"]
                    [:c "Uncle"
                     [:b "Last child" {:selected? true}]]]}}

   :CLIMB-BOUNDARY
   {:name "No-op when already at doc level"
    :tags #{:boundary}
    :setup {:tree [:doc [:a "Top level" {:selected? true}]]}
    :action {:type :move-selected-up}
    :expect {:tree [:doc [:a "Top level" {:selected? true}]]
             :ops {:count 0}}}}}

