{:paths ["dev"]
 :deps {org.babashka/http-client {:mvn/version "0.4.19"}
        cheshire/cheshire {:mvn/version "5.13.0"}
        medley/medley {:mvn/version "1.4.0"}}

 :tasks
 {;; Evaluation tasks
  run-tournament
  {:doc "Run v3 tournament evaluation on items"
   :task (clojure "-M -m dev.eval.core-v3/evaluate! resources/items.edn")}

  run-report
  {:doc "Print evaluation report from results file"
   :task (clojure "-M -m dev.eval.report/print! target/run.edn")}

  run-attacks
  {:doc "Run attack robustness tests on edges"
   :task (clojure "-M -m dev.eval.attacks/run! target/edges.edn")}

  ;; Research workflow scripts
  analyze-battle-test
  {:doc "Analyze battle-test results with Codex"
   :requires ([scripts.research.analyze-battle-test])
   :task (apply scripts.research.analyze-battle-test/-main *command-line-args*)}

  best-repos-research
  {:doc "Research best-of repos for architectural patterns (15 parallel queries)"
   :requires ([scripts.research.best-repos-research])
   :task (apply scripts.research.best-repos-research/-main *command-line-args*)}

  architectural-proposals
  {:doc "Generate architectural proposals from multiple LLMs"
   :requires ([scripts.research.architectural-proposals])
   :task (apply scripts.research.architectural-proposals/-main *command-line-args*)}

  gemini-media
  {:doc "Gemini Media API - Video and Image Generation Tool"
   :requires ([scripts.research.gemini-media])
   :task (apply scripts.research.gemini-media/-main *command-line-args*)}

  export-proposals-index
  {:doc "Export proposals to TSV/CSV index for easy review"
   :requires ([scripts.research.export-proposals-index])
   :task (apply scripts.research.export-proposals-index/-main *command-line-args*)}}}
