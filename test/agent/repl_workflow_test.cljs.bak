(ns agent.repl-workflow-test
  (:require [cljs.test :refer-macros [deftest testing is]]
            [agent.repl-workflow :as rw]))

;; Note: These tests assume evolver.kernel is available
;; In a real test environment, you might need to mock or provide a test db

(deftest test-workflow-test
  (testing "runs test workflow"
    (let [test-fns [(fn [_] {:success? true :name "test1" :duration 10})
                    (fn [_] {:success? false :name "test2" :duration 5})]
          result (rw/test-workflow test-fns)]
      (is (= (:status result) :failed))
      (is (= (:passed result) 1))
      (is (= (:total result) 2))
      (is (vector? (:details result))))))

;; Note: test-operations-batch and health-check tests would require
;; setting up a proper test database and mocking evolver.kernel functions
;; For now, we test the structure of the expected results