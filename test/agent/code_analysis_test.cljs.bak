(ns agent.code-analysis-test
  (:require [cljs.test :refer-macros [deftest testing is]]
            [agent.code-analysis :as ca]))

(deftest analyze-namespace-health-test
  (testing "analyzes healthy namespace"
    (let [result (ca/analyze-namespace-health "cljs.core")]
      (is (= (:status result) :healthy))
      (is (number? (:public-fns result)))
      (is (number? (:dependencies result)))))

  (testing "handles non-existent namespace"
    (let [result (ca/analyze-namespace-health "nonexistent.namespace")]
      (is (= (:status result) :not-found)))))

(deftest find-potential-forward-decl-issues-test
  (testing "analyzes file content for forward declaration issues"
    (let [content "(defn foo [] (bar))\n(defn bar [] 42)"
          result (ca/find-potential-forward-decl-issues content)]
      (is (number? (:defined-functions result)))
      (is (vector? (:potentially-undefined result)))
      (is (contains? #{:low :medium :high} (:risk-level result))))))

(deftest validate-db-structure-test
  (testing "validates correct db structure"
    (let [db {:nodes {} :children-by-parent {} :view {:selected #{}} :derived {:depth {} :paths {}} :tx-log []}
          result (ca/validate-db-structure db)]
      (is (:valid? result))
      (is (empty? (:missing-keys result)))))

  (testing "detects missing keys"
    (let [db {:nodes {}}
          result (ca/validate-db-structure db)]
      (is (not (:valid? result)))
      (is (seq (:missing-keys result))))))

(deftest profile-operation-test
  (testing "profiles operation performance"
    (let [op-fn (fn [] {:status :success})
          result (ca/profile-operation op-fn 10)]
      (is (= (:iterations result) 10))
      (is (number? (:total-time-ms result)))
      (is (number? (:avg-time-ms result)))
      (is (map? (:results-summary result))))))